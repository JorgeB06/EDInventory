@model EDInventory.Models.ViewModels.AssetTypeViewModel
@{ ViewData["Title"] = "Editar Tipo de Activo"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tag me-2"></i>Editar Tipo de Activo</h4>
    <a asp-action="AssetTypes" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <form asp-action="AssetTypeEdit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="AssetsTypeCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="AssetsDesc" class="form-label fw-semibold"></label>
                <input asp-for="AssetsDesc" class="form-control" />
                <span asp-validation-for="AssetsDesc" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="GenAssetsTypeCode" class="form-label fw-semibold"></label>
                <select asp-for="GenAssetsTypeCode" asp-items="Model.GenAssetTypes" class="form-select">
                    <option value="">-- Seleccione categoria --</option>
                </select>
                <span asp-validation-for="GenAssetsTypeCode" class="text-danger small"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar cambios</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
