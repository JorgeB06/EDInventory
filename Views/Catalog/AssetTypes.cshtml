@model IEnumerable<EDInventory.Models.Entities.GenAssetType>
@{ ViewData["Title"] = "Tipos de Activo"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tags me-2"></i>Tipos de Activo</h4>
    <a asp-action="GenAssetTypeCreate" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nueva Categoria</a>
</div>

@foreach (var gen in Model)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">
                <i class="bi bi-folder me-1"></i>@gen.GenAssetsDesc
                <span class="badge @(gen.Active ? "bg-success" : "bg-secondary") ms-2">
                    @(gen.Active ? "Activo" : "Inactivo")
                </span>
            </span>
            <div>
                <a asp-action="GenAssetTypeEdit" asp-route-id="@gen.GenAssetsTypeCode"
                   class="btn btn-outline-primary btn-sm me-1">
                    <i class="bi bi-pencil"></i>
                </a>
                <form asp-action="GenAssetTypeToggle" asp-route-id="@gen.GenAssetsTypeCode"
                      method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm @(gen.Active ? "btn-outline-warning" : "btn-outline-success") me-2"
                            title="@(gen.Active ? "Desactivar" : "Activar")">
                        <i class="bi @(gen.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                    </button>
                </form>
                <form asp-action="GenAssetTypeDelete" asp-route-id="@gen.GenAssetsTypeCode"
                      method="post" class="d-inline me-2"
                      onsubmit="return confirm('¿Eliminar esta categoria?')">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Eliminar">
                        <i class="bi bi-trash"></i>
                    </button>
                </form>
                <a asp-action="AssetTypeCreate" asp-route-genId="@gen.GenAssetsTypeCode"
                   class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-plus-lg me-1"></i>Tipo
                </a>
            </div>
        </div>
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tipo de Activo</th>
                        <th class="text-center">Estado</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var at in gen.AssetTypes)
                    {
                        <tr>
                            <td>@at.AssetsDesc</td>
                            <td class="text-center">
                                <span class="badge @(at.Active ? "bg-success" : "bg-secondary")">
                                    @(at.Active ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="text-center">
                                <a asp-action="AssetTypeEdit" asp-route-id="@at.AssetsTypeCode"
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form asp-action="AssetTypeToggle" asp-route-id="@at.AssetsTypeCode"
                                      method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm @(at.Active ? "btn-outline-warning" : "btn-outline-success")"
                                            title="@(at.Active ? "Desactivar" : "Activar")">
                                        <i class="bi @(at.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                    </button>
                                </form>
                                <form asp-action="AssetTypeDelete" asp-route-id="@at.AssetsTypeCode"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('¿Eliminar este tipo de activo?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                    @if (!gen.AssetTypes.Any())
                    {
                        <tr><td colspan="3" class="text-muted small ps-3 py-2">Sin tipos registrados.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
@if (!Model.Any())
{
    <div class="text-center text-muted py-5">No hay categorias registradas.</div>
}
