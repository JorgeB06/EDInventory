@model IEnumerable<EDInventory.Models.Entities.Department>
@{ ViewData["Title"] = "Departamentos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Departamentos</h4>
    <a asp-action="DepartmentCreate" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Nuevo Departamento</a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Sede</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.DepCode</td>
                        <td>@item.DepName</td>
                        <td>@item.Site?.SiteName</td>
                        <td class="text-center">
                            <span class="badge @(item.Active ? "bg-success" : "bg-secondary")">
                                @(item.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="DepartmentEdit" asp-route-id="@item.DepCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DepartmentToggle" asp-route-id="@item.DepCode" method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(item.Active ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi @(item.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay departamentos registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
