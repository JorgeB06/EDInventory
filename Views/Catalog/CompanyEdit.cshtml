@model EDInventory.Models.ViewModels.CompanyViewModel
@{
    ViewData["Title"] = "Editar Empresa";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-building me-2"></i>Editar Empresa</h4>
    <a asp-action="Companies" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:560px;">
    <div class="card-body">
        <form asp-action="CompanyEdit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="CompanyCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <div class="mb-3">
                <label asp-for="CompanyName" class="form-label fw-semibold"></label>
                <input asp-for="CompanyName" class="form-control" />
                <span asp-validation-for="CompanyName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="DoctypeCode" class="form-label fw-semibold"></label>
                <select asp-for="DoctypeCode" asp-items="Model.DocumentTypes" class="form-select">
                    <option value="">-- Seleccione --</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="DocumentType" class="form-label fw-semibold"></label>
                <input asp-for="DocumentType" class="form-control" />
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-floppy me-1"></i>Guardar cambios
            </button>
        </form>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
