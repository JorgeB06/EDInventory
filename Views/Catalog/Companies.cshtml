@model IEnumerable<EDInventory.Models.Entities.Company>
@{
    ViewData["Title"] = "Empresas";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-building me-2"></i>Empresas</h4>
    <a asp-action="CompanyCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nueva Empresa
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Tipo Doc.</th>
                    <th>Num. Documento</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.CompanyCode</td>
                        <td>@item.CompanyName</td>
                        <td>@item.DocumentTypeCompany?.DoctypeDesc</td>
                        <td>@item.DocumentType</td>
                        <td class="text-center">
                            <span class="badge @(item.Active ? "bg-success" : "bg-secondary")">
                                @(item.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="CompanyEdit" asp-route-id="@item.CompanyCode"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="CompanyToggle" asp-route-id="@item.CompanyCode"
                                  method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(item.Active ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(item.Active ? "Desactivar" : "Activar")">
                                    <i class="bi @(item.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay empresas registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
