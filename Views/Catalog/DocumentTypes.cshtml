@model IEnumerable<EDInventory.Models.Entities.DocumentTypeCompany>
@{ ViewData["Title"] = "Tipos de Documento"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Tipos de Documento</h4>
    <a asp-action="DocumentTypeCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Tipo
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Descripcion</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dt in Model)
                {
                    <tr>
                        <td>@dt.DoctypeCode</td>
                        <td class="fw-semibold">@dt.DoctypeDesc</td>
                        <td class="text-center">
                            <span class="badge @(dt.Active ? "bg-success" : "bg-secondary")">
                                @(dt.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="DocumentTypeEdit" asp-route-id="@dt.DoctypeCode"
                               class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DocumentTypeToggle" asp-route-id="@dt.DoctypeCode"
                                  method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm @(dt.Active ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(dt.Active ? "Desactivar" : "Activar")">
                                    <i class="bi @(dt.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                            <form asp-action="DocumentTypeDelete" asp-route-id="@dt.DoctypeCode"
                                  method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar este tipo de documento?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Eliminar">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4">No hay tipos de documento registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
