@model IEnumerable<EDInventory.Models.Entities.ItEquipMaintenance>
@{
    ViewData["Title"] = "Mantenimientos Pendientes — TI";
    var today         = (DateOnly)ViewBag.Today;
    int? currentUserId = ViewBag.CurrentUserId as int?;
    bool isAdmin      = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin);
    bool canComplete  = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.TiTecnico);

    var misAsignaciones = currentUserId.HasValue
        ? Model.Where(m => m.UserCode == currentUserId.Value).ToList()
        : new List<EDInventory.Models.Entities.ItEquipMaintenance>();
    var resto     = currentUserId.HasValue
        ? Model.Where(m => m.UserCode != currentUserId.Value).ToList()
        : Model.ToList();
    var vencidos  = resto.Where(m => m.MaintScheduled < today).ToList();
    var proximos  = resto.Where(m => m.MaintScheduled >= today && m.MaintScheduled <= today.AddDays(30)).ToList();
    var futuros   = resto.Where(m => m.MaintScheduled > today.AddDays(30)).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-wrench-adjustable me-2"></i>Mantenimientos Pendientes — TI</h4>
    <div class="d-flex gap-2 align-items-center flex-wrap">
        @if (vencidos.Any()) { <span class="badge bg-danger">@vencidos.Count vencido(s)</span> }
        @if (proximos.Any()) { <span class="badge bg-warning text-dark">@proximos.Count en 30 dias</span> }
        <span class="badge bg-secondary">@Model.Count() total</span>
        <a asp-action="MaintHistory" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-clock-history me-1"></i>Historial
        </a>
        @if (isAdmin)
        {
            <a asp-action="MaintBulkCreate" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-building me-1"></i>Masivo
            </a>
            <a asp-action="MaintCreate" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Programar
            </a>
        }
    </div>
</div>

@* F2: Mis asignaciones *@
@if (misAsignaciones.Any())
{
    <div class="card shadow-sm border-primary mb-4">
        <div class="card-header fw-bold" style="background:#0d1b4b; color:#fff;">
            <i class="bi bi-person-check-fill me-1"></i>Mis Asignaciones (@misAsignaciones.Count)
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr><th>Equipo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Notas</th><th style="width:90px"></th></tr>
                </thead>
                <tbody>
                    @foreach (var m in misAsignaciones.OrderBy(x => x.MaintScheduled))
                    {
                        var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                        var esVencido = dias < 0;
                        <tr class="@(esVencido ? "table-danger" : dias <= 7 ? "table-warning" : "")">
                            <td class="fw-semibold small"><a asp-action="Detail" asp-route-id="@m.ItequipCode" class="text-decoration-none text-dark">@m.ItEquip?.ItequipDesc</a></td>
                            <td class="small text-muted">@(m.ItEquip?.Hospital?.HospName ?? "—")</td>
                            <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : "bg-danger")">@m.MaintType</span></td>
                            <td class="small">
                                @m.MaintScheduled.ToString("dd/MM/yyyy")
                                @if (esVencido) { <span class="badge bg-danger ms-1">@Math.Abs(dias)d venc.</span> }
                                else { <span class="badge bg-warning text-dark ms-1">@dias d</span> }
                            </td>
                            <td class="small text-muted">@(m.MaintNotes ?? "—")</td>
                            <td class="text-end">
                                @if (canComplete)
                                {
                                    <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-success btn-sm py-0 px-1" title="Completar">
                                        <i class="bi bi-check-lg"></i>
                                    </a>
                                }
                                @if (isAdmin)
                                {
                                    <a asp-action="MaintReassign" asp-route-id="@m.MaintCode" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" title="Reasignar">
                                        <i class="bi bi-person-fill-gear"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
        No hay mantenimientos pendientes.
    </div>
}
else if (!resto.Any() && misAsignaciones.Any())
{
    <div class="text-center text-muted py-3 small">No hay otros mantenimientos pendientes.</div>
}
else
{
    @* Vencidos *@
    @if (vencidos.Any())
    {
        <div class="card shadow-sm border-danger mb-3">
            <div class="card-header bg-danger text-white fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>Vencidos (@vencidos.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Equipo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th style="width:50px"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in vencidos)
                        {
                            var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                            <tr class="table-danger">
                                <td class="fw-semibold small"><a asp-action="Detail" asp-route-id="@m.ItequipCode" class="text-decoration-none text-dark">@m.ItEquip?.ItequipDesc</a></td>
                                <td class="small text-muted">@(m.ItEquip?.Hospital?.HospName ?? "—")</td>
                                <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="badge bg-danger ms-1">@Math.Abs(dias)d</span></td>
                                <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                <td class="text-end">
                                    @if (canComplete) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }
                                    @if (isAdmin) { <a asp-action="MaintReassign" asp-route-id="@m.MaintCode" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" title="Reasignar"><i class="bi bi-person-fill-gear"></i></a> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Proximos 30 dias *@
    @if (proximos.Any())
    {
        <div class="card shadow-sm border-warning mb-3">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-calendar-event me-1"></i>Proximos 30 Dias (@proximos.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Equipo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th>Notas</th><th style="width:50px"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in proximos.OrderBy(x => x.MaintScheduled))
                        {
                            var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                            string rowClass = dias <= 7 ? "table-warning" : "";
                            <tr class="@rowClass">
                                <td class="fw-semibold small"><a asp-action="Detail" asp-route-id="@m.ItequipCode" class="text-decoration-none text-dark">@m.ItEquip?.ItequipDesc</a></td>
                                <td class="small text-muted">@(m.ItEquip?.Hospital?.HospName ?? "—")</td>
                                <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="badge bg-warning text-dark ms-1">@dias d</span></td>
                                <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                <td class="small text-muted">@(m.MaintNotes ?? "—")</td>
                                <td class="text-end">
                                    @if (canComplete) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }
                                    @if (isAdmin) { <a asp-action="MaintReassign" asp-route-id="@m.MaintCode" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" title="Reasignar"><i class="bi bi-person-fill-gear"></i></a> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Futuros (+30 dias) *@
    @if (futuros.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white fw-bold"
                 style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#colFuturos">
                <i class="bi bi-calendar3 me-1"></i>Mas de 30 Dias (@futuros.Count)
                <i class="bi bi-chevron-down small float-end"></i>
            </div>
            <div class="collapse" id="colFuturos">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Equipo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th>Notas</th><th style="width:50px"></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in futuros.OrderBy(x => x.MaintScheduled))
                            {
                                var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                                <tr>
                                    <td class="fw-semibold small"><a asp-action="Detail" asp-route-id="@m.ItequipCode" class="text-decoration-none text-dark">@m.ItEquip?.ItequipDesc</a></td>
                                    <td class="small text-muted">@(m.ItEquip?.Hospital?.HospName ?? "—")</td>
                                    <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                    <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="text-muted small ms-1">(@dias d)</span></td>
                                    <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                    <td class="small text-muted">@(m.MaintNotes ?? "—")</td>
                                    <td class="text-end">
                                    @if (canComplete) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }
                                    @if (isAdmin) { <a asp-action="MaintReassign" asp-route-id="@m.MaintCode" class="btn btn-outline-secondary btn-sm py-0 px-1 ms-1" title="Reasignar"><i class="bi bi-person-fill-gear"></i></a> }
                                </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
