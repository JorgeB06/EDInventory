@model EDInventory.Models.Entities.ItEquip
@using EDInventory.Models.Entities
@{
    ViewData["Title"] = Model.ItequipDesc ?? "Detalle Equipo";
    var equipMovements = ViewBag.EquipMovements  as List<ItEquipMovement>   ?? new List<ItEquipMovement>();
    var maintenances   = ViewBag.Maintenances    as List<ItEquipMaintenance> ?? new List<ItEquipMaintenance>();
    var incidents      = ViewBag.Incidents       as List<Incident>           ?? new List<Incident>();
    var documents      = ViewBag.Documents       as List<Document>           ?? new List<Document>();
    var today          = DateOnly.FromDateTime(DateTime.Today);
    bool canWrite = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.TiTecnico);
    bool canManage = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.SvcAdmin);

    string statusBadge = Model.EquipStatus switch {
        "EN_REPARACION"  => "bg-danger",
        "EN_EVALUACION"  => "bg-warning text-dark",
        "DADO_DE_BAJA"   => "bg-secondary",
        _                => "bg-success"
    };
    string statusLabel = Model.EquipStatus switch {
        "EN_REPARACION"  => "En Reparación",
        "EN_EVALUACION"  => "En Evaluación",
        "DADO_DE_BAJA"   => "Dado de Baja",
        _                => "En Servicio"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">
        <i class="bi bi-laptop me-2"></i>@Model.ItequipDesc
        <span class="badge @statusBadge ms-2 fs-6">@statusLabel</span>
    </h4>
    <div class="d-flex gap-2">
        <a asp-action="Label" asp-route-id="@Model.ItequipCode" target="_blank"
           class="btn btn-outline-dark btn-sm">
            <i class="bi bi-tag me-1"></i>Imprimir Etiqueta
        </a>
        @if (canWrite)
        {
            <a asp-action="MaintCreate" asp-route-equipCode="@Model.ItequipCode" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-wrench-adjustable me-1"></i>Mantenimiento
            </a>
            <a asp-controller="Incident" asp-action="Create" asp-route-entityType="TI" asp-route-entityCode="@Model.ItequipCode"
               class="btn btn-outline-danger btn-sm">
                <i class="bi bi-tools me-1"></i>Incidente
            </a>
            <a asp-action="EquipWithdraw" asp-route-id="@Model.ItequipCode" class="btn btn-outline-warning btn-sm">
                <i class="bi bi-box-arrow-right me-1"></i>Retiro / Devolución
            </a>
            <a asp-action="Edit" asp-route-id="@Model.ItequipCode" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Editar
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="row g-3">
    <!-- Informacion General -->
    <div class="col-md-6">
        <div class="card shadow-sm h-100">
            <div class="card-header fw-bold bg-dark text-white">
                <i class="bi bi-info-circle me-1"></i>Informacion General
            </div>
            <div class="card-body">
                <dl class="row mb-0 small">
                    <dt class="col-5">Tipo de Activo</dt>
                    <dd class="col-7">@Model.Model?.Brand?.AssetType?.GenAssetType?.GenAssetsDesc / @Model.Model?.Brand?.AssetType?.AssetsDesc</dd>

                    <dt class="col-5">Marca / Modelo</dt>
                    <dd class="col-7">@Model.Model?.Brand?.BrandDesc — @Model.Model?.ModelDesc</dd>

                    <dt class="col-5">Numero de Serie</dt>
                    <dd class="col-7">@(Model.ItequipSn ?? "—")</dd>

                    <dt class="col-5">Numero de Equipo</dt>
                    <dd class="col-7">@(Model.ItequipNum ?? "—")</dd>

                    <dt class="col-5">Num. Garantia</dt>
                    <dd class="col-7">@(Model.ItequipGnum ?? "—")</dd>

                    <dt class="col-5">Estado Inventario</dt>
                    <dd class="col-7">
                        <span class="badge @(Model.Active ? "bg-success" : "bg-secondary")">
                            @(Model.Active ? "Activo" : "Inactivo")
                        </span>
                    </dd>

                    <dt class="col-5">Estado Equipo</dt>
                    <dd class="col-7">
                        <span class="badge @statusBadge">@statusLabel</span>
                    </dd>

                    <dt class="col-5">Fecha Registro</dt>
                    <dd class="col-7">@Model.ItequipDnew?.ToString("dd/MM/yyyy")</dd>

                    <dt class="col-5">Ultima Modif.</dt>
                    <dd class="col-7">@Model.ItequipDmod?.ToString("dd/MM/yyyy")</dd>

                    @if (Model.ItequipDjequip.HasValue)
                    {
                        <dt class="col-5">Fecha Baja</dt>
                        <dd class="col-7 text-danger">@Model.ItequipDjequip?.ToString("dd/MM/yyyy")</dd>
                    }
                </dl>
            </div>
        </div>
    </div>

    <!-- Ubicacion actual -->
    <div class="col-md-6">
        <div class="card shadow-sm mb-3">
            <div class="card-header fw-bold bg-dark text-white">
                <i class="bi bi-geo-alt me-1"></i>Ubicacion Actual
            </div>
            <div class="card-body small">
                @if (Model.WareCode.HasValue)
                {
                    <dl class="row mb-0">
                        <dt class="col-4">Bodega</dt>
                        <dd class="col-8"><i class="bi bi-box-seam me-1 text-primary"></i>@Model.Warehouse?.WareName</dd>
                        <dt class="col-4">Rack</dt>
                        <dd class="col-8">@(Model.WareRack ?? "—")</dd>
                        <dt class="col-4">Estante</dt>
                        <dd class="col-8">@(Model.WareEstante ?? "—")</dd>
                        <dt class="col-4">Caja</dt>
                        <dd class="col-8">@(Model.WareCaja ?? "—")</dd>
                    </dl>
                }
                else if (Model.HospCode.HasValue)
                {
                    <dl class="row mb-0">
                        <dt class="col-4">Hospital</dt>
                        <dd class="col-8"><i class="bi bi-hospital me-1 text-primary"></i>@Model.Hospital?.HospName</dd>
                        <dt class="col-4">Zona</dt>
                        <dd class="col-8">@(Model.HospitalDepartment?.HospDepName ?? "—")</dd>
                        <dt class="col-4">Posicion</dt>
                        <dd class="col-8">@(Model.ItequipHospPos ?? "—")</dd>
                    </dl>
                }
                else if (Model.SiteCode.HasValue)
                {
                    <dl class="row mb-0">
                        <dt class="col-4">Sede</dt>
                        <dd class="col-8"><i class="bi bi-geo-alt me-1 text-primary"></i>@Model.Site?.SiteName</dd>
                    </dl>
                }
                else
                {
                    <span class="text-muted">Sin ubicacion asignada.</span>
                }
            </div>
        </div>

        <!-- Licitacion -->
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-dark text-white">
                <i class="bi bi-file-earmark-text me-1"></i>Licitacion
            </div>
            <div class="card-body small">
                @if (Model.Licitacion != null)
                {
                    var detHoy     = DateOnly.FromDateTime(DateTime.Today);
                    var detVencida  = Model.Licitacion.LicEnd.HasValue && Model.Licitacion.LicEnd < detHoy && !Model.Licitacion.LicPostponed;
                    var detAplazada = Model.Licitacion.LicEnd.HasValue && Model.Licitacion.LicEnd < detHoy &&  Model.Licitacion.LicPostponed;
                    var detSoon     = Model.Licitacion.LicEnd.HasValue && !detVencida && !detAplazada &&
                                      Model.Licitacion.LicEnd <= DateOnly.FromDateTime(DateTime.Today.AddDays(Model.Licitacion.LicWarnDays));
                    <dl class="row mb-0">
                        <dt class="col-5">Num. Licitacion</dt>
                        <dd class="col-7">@Model.Licitacion.LicNum</dd>
                        <dt class="col-5">Descripcion</dt>
                        <dd class="col-7">@Model.Licitacion.LicDesc</dd>
                        <dt class="col-5">Inicio</dt>
                        <dd class="col-7">@(Model.Licitacion.LicStart?.ToString("dd/MM/yyyy") ?? "—")</dd>
                        <dt class="col-5">Vencimiento</dt>
                        <dd class="col-7 @(detVencida ? "text-danger fw-bold" : detAplazada ? "text-warning fw-bold" : detSoon ? "text-warning fw-bold" : "")">
                            @(Model.Licitacion.LicEnd?.ToString("dd/MM/yyyy") ?? "—")
                            @if (detVencida)  { <span class="badge bg-danger ms-1"><i class="bi bi-exclamation-triangle-fill me-1"></i>Vencida</span> }
                            else if (detAplazada) { <span class="badge bg-warning text-dark ms-1"><i class="bi bi-pause-circle-fill me-1"></i>Aplazada</span> }
                            else if (detSoon)  { <span class="badge bg-warning text-dark ms-1"><i class="bi bi-clock-history me-1"></i>Por vencer</span> }
                            else if (Model.Licitacion.LicEnd.HasValue) { <span class="badge bg-success ms-1">Vigente</span> }
                        </dd>
                        @if (detAplazada && !string.IsNullOrWhiteSpace(Model.Licitacion.LicPostponedNote))
                        {
                            <dt class="col-5">Nota aplazamiento</dt>
                            <dd class="col-7 text-muted"><i class="bi bi-info-circle me-1"></i>@Model.Licitacion.LicPostponedNote</dd>
                        }
                    </dl>
                }
                else
                {
                    <span class="text-muted">Sin licitacion asignada.</span>
                }
            </div>
        </div>
    </div>

    <!-- Red -->
    @if (!string.IsNullOrEmpty(Model.NetHostname) || Model.NetEnabled || Model.NetInDomain)
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold bg-dark text-white">
                    <i class="bi bi-wifi me-1"></i>Conectividad de Red
                    @if (Model.NetEnabled)
                    {
                        <span class="badge bg-success ms-2"><i class="bi bi-wifi me-1"></i>En red</span>
                    }
                    @if (Model.NetInDomain)
                    {
                        <span class="badge bg-info text-dark ms-1">Dominio</span>
                    }
                </div>
                <div class="card-body">
                    <dl class="row mb-0 small">
                        @if (!string.IsNullOrEmpty(Model.NetHostname))
                        {
                            <dt class="col-4">Hostname</dt>
                            <dd class="col-8 fw-semibold font-monospace">@Model.NetHostname</dd>
                        }
                        <dt class="col-4">En Dominio</dt>
                        <dd class="col-8">@(Model.NetInDomain ? "Sí" : "No")</dd>
                        <dt class="col-4">Conectado a Red</dt>
                        <dd class="col-8">@(Model.NetEnabled ? "Sí" : "No")</dd>
                        @if (Model.NetEnabled && !string.IsNullOrEmpty(Model.NetIp))
                        {
                            <dt class="col-4">Direccion IP</dt>
                            <dd class="col-8 font-monospace">@Model.NetIp
                                @if (!string.IsNullOrEmpty(Model.NetType))
                                {
                                    <span class="badge @(Model.NetType == "STATIC" ? "bg-secondary" : "bg-primary") ms-1">@Model.NetType</span>
                                }
                            </dd>
                        }
                    </dl>
                </div>
            </div>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(Model.ItequipAddata))
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold bg-dark text-white">
                    <i class="bi bi-card-text me-1"></i>Datos Adicionales
                </div>
                <div class="card-body small">@Model.ItequipAddata</div>
            </div>
        </div>
    }

    @{
        bool hasResponsible = Model.ResponsibleUser.HasValue || !string.IsNullOrEmpty(Model.ResponsibleExt);
        bool hasCost        = Model.AcquireCost.HasValue || Model.AcquireDate.HasValue || Model.DepreYears.HasValue;
    }
    @if (hasResponsible || hasCost)
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold bg-dark text-white">
                    <i class="bi bi-person-badge me-1"></i>Responsable y Costo
                </div>
                <div class="card-body">
                    <div class="row g-3 small">
                        @if (hasResponsible)
                        {
                            <div class="col-md-4">
                                <div class="fw-semibold text-muted mb-1">Responsable Interno</div>
                                @* TODO: join user name — currently FK only *@
                                @(Model.ResponsibleUser.HasValue ? $"Usuario #{Model.ResponsibleUser}" : "—")
                            </div>
                            <div class="col-md-4">
                                <div class="fw-semibold text-muted mb-1">Responsable Externo</div>
                                @(Model.ResponsibleExt ?? "—")
                            </div>
                        }
                        @if (hasCost)
                        {
                            <div class="col-md-4">
                                <div class="fw-semibold text-muted mb-1">Costo de Adquisicion</div>
                                @(Model.AcquireCost.HasValue ? $"$ {Model.AcquireCost:N2}" : "—")
                            </div>
                            <div class="col-md-4">
                                <div class="fw-semibold text-muted mb-1">Fecha de Adquisicion</div>
                                @(Model.AcquireDate?.ToString("dd/MM/yyyy") ?? "—")
                            </div>
                            <div class="col-md-4">
                                <div class="fw-semibold text-muted mb-1">Vida Util</div>
                                @(Model.DepreYears.HasValue ? $"{Model.DepreYears} años" : "—")
                            </div>
                            @if (Model.AcquireCost.HasValue && Model.AcquireDate.HasValue && Model.DepreYears.HasValue && Model.DepreYears > 0)
                            {
                                var yearsElapsed = (DateTime.Today - Model.AcquireDate.Value.ToDateTime(TimeOnly.MinValue)).TotalDays / 365.25;
                                var bookValue    = Model.AcquireCost.Value - (Model.AcquireCost.Value / Model.DepreYears.Value * (decimal)yearsElapsed);
                                bookValue = Math.Max(0, bookValue);
                                var depreClass = bookValue <= 0 ? "text-danger" : yearsElapsed >= Model.DepreYears.Value * 0.8 ? "text-warning" : "text-success";
                                <div class="col-md-4">
                                    <div class="fw-semibold text-muted mb-1">Valor Libro Estimado</div>
                                    <span class="fw-bold @depreClass">$ @bookValue.ToString("N2")</span>
                                    <small class="text-muted ms-1">(@yearsElapsed.ToString("F1") años transcurridos)</small>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.Details.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold bg-dark text-white">
                    <i class="bi bi-list-ul me-1"></i>Detalles del Equipo
                </div>
                <div class="card-body p-0">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr><th>#</th><th>Detalle</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var d in Model.Details)
                            {
                                <tr>
                                    <td>@d.ItequipDetailCode</td>
                                    <td>@d.Detail</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Mantenimientos -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-dark text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-wrench-adjustable me-1"></i>Mantenimientos</span>
                @if (canWrite)
                {
                    <a asp-action="MaintCreate" asp-route-equipCode="@Model.ItequipCode"
                       class="btn btn-outline-light btn-sm">
                        <i class="bi bi-plus me-1"></i>Programar
                    </a>
                }
            </div>
            @if (!maintenances.Any())
            {
                <div class="card-body text-muted small">Sin mantenimientos registrados.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th>Tipo</th>
                                <th>Estado</th>
                                <th>Programado</th>
                                <th>Completado</th>
                                <th>Técnico</th>
                                <th>Notas / Resultado</th>
                                @if (canWrite)
                                {
                                    <th style="width:80px"></th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in maintenances)
                            {
                                var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                                string rowBg = m.MaintStatus == "COMPLETADO" ? "" :
                                               m.MaintStatus == "CANCELADO"  ? "table-secondary" :
                                               dias < 0 ? "table-danger" : dias <= 7 ? "table-warning" : "";
                                <tr class="@rowBg">
                                    <td>
                                        <span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">
                                            @m.MaintType
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(m.MaintStatus == "COMPLETADO" ? "bg-success" : m.MaintStatus == "CANCELADO" ? "bg-secondary" : "bg-warning text-dark")">
                                            @m.MaintStatus
                                        </span>
                                    </td>
                                    <td>@m.MaintScheduled.ToString("dd/MM/yyyy")</td>
                                    <td>@(m.MaintCompleted?.ToString("dd/MM/yyyy") ?? "—")</td>
                                    <td>
                                        @(m.User?.Employee != null
                                            ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}"
                                            : m.User?.UserLogin ?? "—")
                                    </td>
                                    <td class="text-muted">
                                        @(m.MaintStatus == "COMPLETADO" ? m.MaintResult : m.MaintNotes)
                                    </td>
                                    @if (canWrite)
                                    {
                                        <td class="text-end">
                                            @if (m.MaintStatus == "PENDIENTE")
                                            {
                                                <a asp-action="MaintComplete" asp-route-id="@m.MaintCode"
                                                   class="btn btn-outline-success btn-sm py-0 px-1 me-1" title="Completar">
                                                    <i class="bi bi-check-lg"></i>
                                                </a>
                                                <form asp-action="MaintCancel" asp-route-id="@m.MaintCode" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Cancelar">
                                                        <i class="bi bi-x-lg"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Retiros y Devoluciones -->
    @if (equipMovements.Any())
    {
        <div class="col-12">
            <div class="card shadow-sm">
                <div class="card-header fw-bold bg-dark text-white">
                    <i class="bi bi-arrow-left-right me-1"></i>Retiros y Devoluciones
                </div>
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Tipo</th>
                                <th>Destino / Procedencia</th>
                                <th>Hospital</th>
                                <th>Usuario</th>
                                <th>Notas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in equipMovements)
                            {
                                <tr>
                                    <td class="text-muted text-nowrap">@m.MovDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (m.MovType == "RETIRO")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-box-arrow-right me-1"></i>Retiro</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success"><i class="bi bi-box-arrow-in-left me-1"></i>Devolución</span>
                                        }
                                    </td>
                                    <td>@(m.MovDest ?? "—")</td>
                                    <td>@(m.Hospital?.HospName ?? "—")</td>
                                    <td>
                                        @(m.User?.Employee != null
                                            ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}"
                                            : m.User?.UserLogin ?? "—")
                                    </td>
                                    <td class="text-muted">@(m.MovNotes ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }

    <!-- Incidentes -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-dark text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-tools me-1"></i>Incidentes y Reparaciones</span>
                @if (canWrite)
                {
                    <a asp-controller="Incident" asp-action="Create" asp-route-entityType="TI" asp-route-entityCode="@Model.ItequipCode"
                       class="btn btn-outline-light btn-sm">
                        <i class="bi bi-plus me-1"></i>Nuevo
                    </a>
                }
            </div>
            @if (!incidents.Any())
            {
                <div class="card-body text-muted small">Sin incidentes registrados.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0 small">
                        <thead class="table-light">
                            <tr><th>Titulo</th><th>Tipo</th><th>Prioridad</th><th>Estado</th><th>Fecha</th><th></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var inc in incidents)
                            {
                                string priBadge = inc.IncidentPriority switch { "CRITICA" => "bg-danger", "ALTA" => "bg-warning text-dark", "MEDIA" => "bg-info text-dark", _ => "bg-secondary" };
                                string stBadge  = inc.IncidentStatus switch { "CERRADA" => "bg-success", "CANCELADA" => "bg-secondary", "EN_PROCESO" => "bg-warning text-dark", _ => "bg-primary" };
                                <tr>
                                    <td class="fw-semibold">@inc.IncidentTitle</td>
                                    <td>@inc.IncidentType</td>
                                    <td><span class="badge @priBadge">@inc.IncidentPriority</span></td>
                                    <td><span class="badge @stBadge">@inc.IncidentStatus</span></td>
                                    <td>@inc.IncidentDate.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <a asp-controller="Incident" asp-action="Detail" asp-route-id="@inc.IncidentCode"
                                           class="btn btn-outline-primary btn-sm py-0 px-1">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    <!-- Documentos -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-dark text-white d-flex justify-content-between align-items-center">
                <span><i class="bi bi-paperclip me-1"></i>Documentos Adjuntos</span>
            </div>
            <div class="card-body">
                @if (documents.Any())
                {
                    <div class="table-responsive mb-3">
                        <table class="table table-sm mb-0 small">
                            <thead class="table-light">
                                <tr><th>Nombre</th><th>Tipo</th><th>Tamano</th><th>Fecha</th><th>Notas</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var doc in documents)
                                {
                                    <tr>
                                        <td><i class="bi bi-file-earmark me-1 text-muted"></i>@doc.DocName</td>
                                        <td><span class="badge bg-secondary">@doc.DocType</span></td>
                                        <td class="text-muted">@((doc.DocFileSize ?? 0) / 1024) KB</td>
                                        <td class="text-muted">@doc.DocUploadDate.ToString("dd/MM/yyyy")</td>
                                        <td class="text-muted">@(doc.DocNotes ?? "—")</td>
                                        <td class="text-nowrap">
                                            <a asp-controller="Document" asp-action="Download" asp-route-id="@doc.DocCode"
                                               class="btn btn-outline-primary btn-sm py-0 px-1 me-1" title="Descargar">
                                                <i class="bi bi-download"></i>
                                            </a>
                                            @if (canManage)
                                            {
                                                <form asp-controller="Document" asp-action="Delete" asp-route-id="@doc.DocCode"
                                                      method="post" class="d-inline"
                                                      onsubmit="return confirm('¿Eliminar este documento?')">
                                                    @Html.AntiForgeryToken()
                                                    <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Eliminar">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                @if (canWrite)
                {
                    <form asp-controller="Document" asp-action="Upload" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="entityType"  value="TI" />
                        <input type="hidden" name="itequipCode" value="@Model.ItequipCode" />
                        <div class="row g-2 align-items-end">
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Archivo (PDF, imagen, Word, Excel — max 20 MB)</label>
                                <input type="file" name="file" class="form-control form-control-sm" accept=".pdf,.jpg,.jpeg,.png,.docx,.doc,.xlsx,.xls" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label small fw-semibold">Tipo</label>
                                <select name="docType" class="form-select form-select-sm">
                                    <option value="MANUAL">Manual</option>
                                    <option value="CERTIFICADO">Certificado</option>
                                    <option value="ACTA">Acta</option>
                                    <option value="REPORTE">Reporte</option>
                                    <option value="CONTRATO">Contrato</option>
                                    <option value="OTRO" selected>Otro</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-semibold">Notas</label>
                                <input type="text" name="docNotes" class="form-control form-control-sm" maxlength="200" />
                            </div>
                            <div class="col-md-2">
                                <button type="submit" class="btn btn-primary btn-sm w-100">
                                    <i class="bi bi-upload me-1"></i>Adjuntar
                                </button>
                            </div>
                        </div>
                    </form>
                }
            </div>
        </div>
    </div>

    <!-- Historial de movimientos -->
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header fw-bold bg-dark text-white">
                <i class="bi bi-clock-history me-1"></i>Historial de Movimientos
            </div>
            <div class="card-body p-0">
                @if (Model.History.Any())
                {
                    <table class="table table-sm mb-0 small">
                        <thead class="table-light">
                            <tr>
                                <th>Fecha</th>
                                <th>Cambio</th>
                                <th>Detalle</th>
                                <th>Notas</th>
                                <th>Usuario</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var h in Model.History.OrderByDescending(x => x.HistDate))
                            {
                                <tr>
                                    <td class="text-nowrap text-muted small">@h.HistDate.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (h.HistType == "CREACION")
                                        {
                                            <span class="badge bg-success"><i class="bi bi-plus-circle me-1"></i>Creacion</span>
                                        }
                                        else if (h.HistType == "RED")
                                        {
                                            <span class="badge bg-info text-dark"><i class="bi bi-wifi me-1"></i>Red</span>
                                        }
                                        else if (h.HistType == "DATOS")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="bi bi-pencil me-1"></i>Datos</span>
                                        }
                                        else
                                        {
                                            @if (h.LocType == "HOSPITAL")
                                            { <span class="badge bg-primary"><i class="bi bi-hospital me-1"></i>Ubicacion</span> }
                                            else if (h.LocType == "BODEGA")
                                            { <span class="badge bg-secondary"><i class="bi bi-box-seam me-1"></i>Ubicacion</span> }
                                            else if (h.LocType == "SEDE")
                                            { <span class="badge bg-purple"><i class="bi bi-geo-alt me-1"></i>Ubicacion</span> }
                                            else
                                            { <span class="badge bg-light text-dark">Ubicacion</span> }
                                        }
                                    </td>
                                    <td class="small">
                                        @if (h.HistType == "RED")
                                        {
                                            @if (!string.IsNullOrEmpty(h.NetHostname)) { <span class="font-monospace">@h.NetHostname</span><br /> }
                                            @if (h.NetEnabled == true && !string.IsNullOrEmpty(h.NetIp)) { <span class="text-muted">IP: @h.NetIp @(h.NetType != null ? $"({h.NetType})" : "")</span> }
                                            else if (h.NetEnabled == false) { <span class="text-muted">Sin red</span> }
                                        }
                                        else if (h.HistType is null or "UBICACION" or "CREACION")
                                        {
                                            @if (h.LocType == "HOSPITAL")
                                            {
                                                <span>@h.Hospital?.HospName</span>
                                                @if (h.HospitalDepartment != null)
                                                { <br /><small class="text-muted">@h.HospitalDepartment.HospDepName @(!string.IsNullOrWhiteSpace(h.ItequipHospPos) ? $"— {h.ItequipHospPos}" : "")</small> }
                                            }
                                            else if (h.LocType == "BODEGA")
                                            {
                                                <span>@h.Warehouse?.WareName</span>
                                                @if (!string.IsNullOrWhiteSpace(h.WareRack))
                                                { <br /><small class="text-muted">Rack @h.WareRack / Est @h.WareEstante</small> }
                                            }
                                            else if (h.LocType == "SEDE") { <span>@h.Site?.SiteName</span> }
                                        }
                                    </td>
                                    <td class="text-muted small">@(h.HistNotes ?? "—")</td>
                                    <td class="text-muted small">@(h.User?.UserLogin ?? "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="text-center text-muted py-3 small">No hay movimientos registrados.</div>
                }
            </div>
        </div>
    </div>
</div>
