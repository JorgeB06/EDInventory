@model EDInventory.Models.ViewModels.MaintBulkCreateVM
@{
    ViewData["Title"] = "Creación Masiva — Mantenimientos TI";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-building me-2"></i>Creación Masiva — Mantenimientos TI</h4>
    <a asp-action="MaintenanceDue" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="alert alert-info small">
    Crea un mantenimiento pendiente para <strong>todos los equipos activos</strong> del hospital seleccionado.
    Si un equipo ya tiene un mantenimiento pendiente, se creará uno adicional.
</div>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-header fw-bold">Parámetros</div>
    <div class="card-body">
        <form asp-action="MaintBulkCreate" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger small mb-2"></div>
            <div class="mb-3">
                <label asp-for="HospCode" class="form-label fw-semibold">Hospital *</label>
                <select asp-for="HospCode" asp-items="Model.Hospitals" class="form-select">
                    <option value="">— Seleccione hospital —</option>
                </select>
                <span asp-validation-for="HospCode" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UserCode" class="form-label fw-semibold">Técnico Asignado *</label>
                <select asp-for="UserCode" asp-items="Model.Technicians" class="form-select">
                    <option value="">— Seleccione técnico —</option>
                </select>
                <span asp-validation-for="UserCode" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MaintType" class="form-label fw-semibold">Tipo *</label>
                <select asp-for="MaintType" class="form-select">
                    <option value="PREVENTIVO">Preventivo</option>
                    <option value="CORRECTIVO">Correctivo</option>
                </select>
            </div>
            <div class="mb-3">
                <label asp-for="MaintScheduled" class="form-label fw-semibold">Fecha Programada *</label>
                <input asp-for="MaintScheduled" type="date" class="form-control" />
                <span asp-validation-for="MaintScheduled" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MaintNotes" class="form-label">Notas (aplica a todos)</label>
                <textarea asp-for="MaintNotes" class="form-control" rows="2" maxlength="200"></textarea>
            </div>
            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="MaintenanceDue" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Crear Mantenimientos
                </button>
            </div>
        </form>
    </div>
</div>
