@model EDInventory.Models.ViewModels.HospitalDoctorViewModel
@{ ViewData["Title"] = "Nuevo Contacto"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>Nuevo Contacto</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Hospitales</a>
</div>

<div class="card shadow-sm" style="max-width:540px;">
    <div class="card-body">
        <form asp-action="DocCreate" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="HospDocName" class="form-label fw-semibold"></label>
                    <input asp-for="HospDocName" class="form-control" />
                    <span asp-validation-for="HospDocName" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="HospDocSurname" class="form-label fw-semibold"></label>
                    <input asp-for="HospDocSurname" class="form-control" />
                    <span asp-validation-for="HospDocSurname" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="HospDocMail" class="form-label fw-semibold"></label>
                    <input asp-for="HospDocMail" class="form-control" type="email" />
                    <span asp-validation-for="HospDocMail" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="HospRoleCode" class="form-label fw-semibold"></label>
                    <select asp-for="HospRoleCode" asp-items="Model.HospitalRoles" class="form-select">
                        <option value="">-- Seleccione cargo --</option>
                    </select>
                    <span asp-validation-for="HospRoleCode" class="text-danger small"></span>
                </div>
                <div class="col-12">
                    <label asp-for="HospDocAddata" class="form-label fw-semibold"></label>
                    <textarea asp-for="HospDocAddata" class="form-control" rows="2"></textarea>
                </div>
                <div class="col-12 form-check ms-2">
                    <input asp-for="Active" class="form-check-input" type="checkbox" />
                    <label asp-for="Active" class="form-check-label">Activo</label>
                </div>
            </div>
            <div class="mt-4">
                <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar</button>
            </div>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
