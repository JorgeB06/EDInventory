@model EDInventory.Models.Entities.Hospital
@{
    ViewData["Title"] = Model.HospName ?? "Detalle Hospital";
    bool canWrite = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.SvcAdmin);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h4 class="mb-0"><i class="bi bi-hospital me-2"></i>@Model.HospName</h4>
        <small class="text-muted">
            <i class="bi bi-geo-alt me-1"></i>@Model.HospAddress
            &nbsp;|&nbsp;<i class="bi bi-diagram-2 me-1"></i>@Model.ProcessingUnit?.PuDesc
        </small>
    </div>
    <div class="d-flex gap-2">
        @if (canWrite)
        {
            <a asp-action="DepCreate" asp-route-hospId="@Model.HospCode" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Departamento
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

@foreach (var dep in Model.HospitalDepartments)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span class="fw-bold">
                <i class="bi bi-grid me-1"></i>@dep.HospDepName
                <span class="badge @(dep.Active ? "bg-success" : "bg-secondary") ms-2">
                    @(dep.Active ? "Activo" : "Inactivo")
                </span>
            </span>
            <div class="d-flex gap-1">
                @if (canWrite)
                {
                    <a asp-action="RoleCreate" asp-route-depId="@dep.HospDepCode"
                       class="btn btn-outline-secondary btn-sm">
                        <i class="bi bi-plus-lg me-1"></i>Cargo
                    </a>
                }
                @if (canWrite)
                {
                    <a asp-action="DepEdit" asp-route-id="@dep.HospDepCode" class="btn btn-outline-primary btn-sm">
                        <i class="bi bi-pencil"></i>
                    </a>
                    <form asp-action="DepToggle" asp-route-id="@dep.HospDepCode" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm @(dep.Active ? "btn-outline-warning" : "btn-outline-success")">
                            <i class="bi @(dep.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                        </button>
                    </form>
                }
            </div>
        </div>

        @foreach (var role in dep.HospitalRoles)
        {
            <div class="card-body border-bottom py-2">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span class="fw-semibold text-secondary">
                        <i class="bi bi-person-badge me-1"></i>@role.HospRoleName
                        <span class="badge @(role.Active ? "bg-success" : "bg-secondary") ms-1" style="font-size:.7rem">
                            @(role.Active ? "Activo" : "Inactivo")
                        </span>
                    </span>
                    <div class="d-flex gap-1">
                        @if (canWrite)
                        {
                            <a asp-action="DocCreate" asp-route-roleId="@role.HospRoleCode"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-person-plus"></i>
                            </a>
                        }
                        @if (canWrite)
                        {
                            <a asp-action="RoleEdit" asp-route-id="@role.HospRoleCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="RoleToggle" asp-route-id="@role.HospRoleCode" method="post">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(role.Active ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi @(role.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>

                <table class="table table-sm mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Nombre</th>
                            <th>Correo</th>
                            <th>Notas</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var doc in role.HospitalDoctors)
                        {
                            <tr>
                                <td>@doc.HospDocSurname @doc.HospDocName</td>
                                <td>@doc.HospDocMail</td>
                                <td>@doc.HospDocAddata</td>
                                <td class="text-center">
                                    <span class="badge @(doc.Active ? "bg-success" : "bg-secondary")">
                                        @(doc.Active ? "Activo" : "Inactivo")
                                    </span>
                                </td>
                                <td class="text-center">
                                    @if (canWrite)
                                    {
                                        <a asp-action="DocEdit" asp-route-id="@doc.HospDocCode"
                                           class="btn btn-outline-primary btn-sm">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DocToggle" asp-route-id="@doc.HospDocCode"
                                              method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit"
                                                    class="btn btn-sm @(doc.Active ? "btn-outline-warning" : "btn-outline-success")">
                                                <i class="bi @(doc.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!role.HospitalDoctors.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-muted small ps-2 py-1">Sin contactos registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        @if (!dep.HospitalRoles.Any())
        {
            <div class="card-body text-muted small py-2">Sin cargos registrados.</div>
        }
    </div>
}
@if (!Model.HospitalDepartments.Any())
{
    <div class="text-center text-muted py-4">Este hospital no tiene departamentos registrados.</div>
}
