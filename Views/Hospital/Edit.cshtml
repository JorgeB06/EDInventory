@model EDInventory.Models.ViewModels.HospitalViewModel
@{ ViewData["Title"] = "Editar Hospital"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-hospital me-2"></i>Editar Hospital</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card shadow-sm" style="max-width:540px;">
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="HospCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="HospName" class="form-label fw-semibold"></label>
                <input asp-for="HospName" class="form-control" />
                <span asp-validation-for="HospName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="HospAddress" class="form-label fw-semibold"></label>
                <input asp-for="HospAddress" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="PuCode" class="form-label fw-semibold"></label>
                <select asp-for="PuCode" asp-items="Model.ProcessingUnits" class="form-select">
                    <option value="">-- Seleccione unidad --</option>
                </select>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar cambios</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
