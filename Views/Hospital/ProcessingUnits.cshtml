@model IEnumerable<EDInventory.Models.Entities.ProcessingUnit>
@{ ViewData["Title"] = "Unidades Programaticas"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-2 me-2"></i>Unidades Programaticas</h4>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Hospitales
        </a>
        <a asp-action="PuCreate" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nueva Unidad
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Descripcion</th>
                    <th>Hospitales</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var pu in Model)
                {
                    <tr>
                        <td>@pu.PuCode</td>
                        <td>@pu.PuDesc</td>
                        <td>@pu.Hospitals.Count(h => h.Active)</td>
                        <td class="text-center">
                            <span class="badge @(pu.Active ? "bg-success" : "bg-secondary")">
                                @(pu.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="PuEdit" asp-route-id="@pu.PuCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="PuToggle" asp-route-id="@pu.PuCode" method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(pu.Active ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi @(pu.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No hay unidades registradas.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
