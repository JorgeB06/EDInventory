@model IEnumerable<EDInventory.Models.Entities.Hospital>
@{
    ViewData["Title"] = "Hospitales";
    bool canWrite = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.SvcAdmin);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-hospital me-2"></i>Hospitales</h4>
    <div class="d-flex gap-2">
        <a asp-action="ProcessingUnits" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-diagram-2 me-1"></i>Unidades Programaticas
        </a>
        @if (canWrite)
        {
            <a asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-plus-lg me-1"></i>Nuevo Hospital
            </a>
        }
    </div>
</div>

<div class="card shadow-sm mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-5">
                <input type="text" name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                       placeholder="Nombre o direccion..." />
            </div>
            <div class="col-md-4">
                <select name="puId" class="form-select form-select-sm" asp-items="ViewBag.ProcessingUnits">
                    <option value="">-- Unidad Programatica --</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-1">
                <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search"></i></button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x-lg"></i></a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3">
    @foreach (var h in Model)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold mb-1">
                                <i class="bi bi-hospital me-1 text-primary"></i>@h.HospName
                            </h6>
                            <p class="text-muted small mb-1">
                                <i class="bi bi-geo-alt me-1"></i>@(h.HospAddress ?? "Sin direccion")
                            </p>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-diagram-2 me-1"></i>@(h.ProcessingUnit?.PuDesc ?? "Sin unidad")
                            </p>
                        </div>
                        <span class="badge @(h.Active ? "bg-success" : "bg-secondary")">
                            @(h.Active ? "Activo" : "Inactivo")
                        </span>
                    </div>
                    <div class="mt-2">
                        <span class="badge bg-light text-dark border">
                            <i class="bi bi-grid me-1"></i>@h.HospitalDepartments.Count dep.
                        </span>
                    </div>
                </div>
                <div class="card-footer d-flex gap-2 bg-transparent">
                    <a asp-action="Detail" asp-route-id="@h.HospCode" class="btn btn-outline-primary btn-sm flex-fill">
                        <i class="bi bi-eye me-1"></i>Detalle
                    </a>
                    @if (canWrite)
                    {
                        <a asp-action="Edit" asp-route-id="@h.HospCode" class="btn btn-outline-secondary btn-sm">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-action="Toggle" asp-route-id="@h.HospCode" method="post"
                              data-confirm="¿Confirma el cambio de estado del hospital?" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm @(h.Active ? "btn-outline-warning" : "btn-outline-success")">
                                <i class="bi @(h.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                            </button>
                        </form>
                    }
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">No hay hospitales registrados.</div>
    }
</div>

@{
    int page       = ViewBag.Page ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    int total      = ViewBag.Total ?? 0;

    string QS(int p) {
        var q = new System.Text.StringBuilder();
        q.Append("?page=").Append(p);
        if (!string.IsNullOrWhiteSpace(ViewBag.Search as string)) q.Append("&search=").Append(Uri.EscapeDataString(ViewBag.Search));
        if (ViewBag.PuId != null) q.Append("&puId=").Append(ViewBag.PuId);
        return q.ToString();
    }
}

<div class="d-flex justify-content-between align-items-center mt-2 flex-wrap gap-2">
    <div class="text-muted small"><strong>@total</strong> hospitales encontrados</div>
    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="@QS(page - 1)"><i class="bi bi-chevron-left"></i></a>
                </li>
                @for (int i = Math.Max(1, page - 2); i <= Math.Min(totalPages, page + 2); i++)
                {
                    <li class="page-item @(i == page ? "active" : "")">
                        <a class="page-link" href="@QS(i)">@i</a>
                    </li>
                }
                <li class="page-item @(page >= totalPages ? "disabled" : "")">
                    <a class="page-link" href="@QS(page + 1)"><i class="bi bi-chevron-right"></i></a>
                </li>
            </ul>
        </nav>
    }
</div>
