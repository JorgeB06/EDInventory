@model EDInventory.Models.ViewModels.UserViewModel
@{ ViewData["Title"] = "Nuevo Usuario"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-plus me-2"></i>Nuevo Usuario</h4>
    <a asp-action="Users" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card shadow-sm" style="max-width:520px;">
    <div class="card-body">
        <form asp-action="UserCreate" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

            <div class="mb-3">
                <label asp-for="UserLogin" class="form-label fw-semibold"></label>
                <input asp-for="UserLogin" class="form-control" maxlength="15" />
                <span asp-validation-for="UserLogin" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label fw-semibold"></label>
                <input asp-for="Password" class="form-control" type="password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                <input asp-for="ConfirmPassword" class="form-control" type="password" />
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="EmpCode" class="form-label fw-semibold"></label>
                <select asp-for="EmpCode" asp-items="Model.Employees" class="form-select">
                    <option value="">-- Seleccione empleado --</option>
                </select>
                <span asp-validation-for="EmpCode" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="UroleCode" class="form-label fw-semibold"></label>
                <select asp-for="UroleCode" asp-items="Model.UserRoles" class="form-select">
                    <option value="">-- Seleccione rol --</option>
                </select>
                <span asp-validation-for="UroleCode" class="text-danger small"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
