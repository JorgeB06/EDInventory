@model IEnumerable<EDInventory.Models.Entities.Employee>
@{ ViewData["Title"] = "Empleados TI"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>Empleados TI</h4>
    <a asp-action="EmployeeCreate" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i>Nuevo Empleado
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Nombre</th>
                    <th>Documento</th>
                    <th>Correo</th>
                    <th>Puesto</th>
                    <th>Sede</th>
                    <th>Ingreso</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var emp in Model)
                {
                    <tr>
                        <td>@emp.EmpCode</td>
                        <td>@emp.EmpSurname @emp.EmpName</td>
                        <td>@emp.EmpDocnum</td>
                        <td>@emp.EmpEmail</td>
                        <td>@emp.Role?.RoleName</td>
                        <td>@emp.Role?.Department?.Site?.SiteName</td>
                        <td>@emp.EmpHighDate?.ToString("dd/MM/yyyy")</td>
                        <td class="text-center">
                            <span class="badge @(emp.Active ? "bg-success" : "bg-secondary")">
                                @(emp.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="EmployeeEdit" asp-route-id="@emp.EmpCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="EmployeeToggle" asp-route-id="@emp.EmpCode" method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(emp.Active ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(emp.Active ? "Desactivar" : "Activar")">
                                    <i class="bi @(emp.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No hay empleados registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
