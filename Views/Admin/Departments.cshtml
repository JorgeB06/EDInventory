@model IEnumerable<EDInventory.Models.Entities.Department>
@{ ViewData["Title"] = "Departamentos"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Departamentos</h4>
    <div class="d-flex gap-2">
        <a asp-action="Positions" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-person-badge me-1"></i>Puestos
        </a>
        <a asp-action="DepartmentCreate" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Departamento
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Departamento</th>
                    <th>Sede</th>
                    <th>Puestos</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var dep in Model)
                {
                    <tr>
                        <td>@dep.DepCode</td>
                        <td class="fw-semibold">@dep.DepName</td>
                        <td>@(dep.Site?.SiteName ?? "—")</td>
                        <td><span class="badge bg-primary bg-opacity-75">@dep.Roles.Count</span></td>
                        <td class="text-center">
                            <span class="badge @(dep.Active ? "bg-success" : "bg-secondary")">
                                @(dep.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="DepartmentEdit" asp-route-id="@dep.DepCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DepartmentToggle" asp-route-id="@dep.DepCode" method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(dep.Active ? "btn-outline-warning" : "btn-outline-success")">
                                    <i class="bi @(dep.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay departamentos registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
