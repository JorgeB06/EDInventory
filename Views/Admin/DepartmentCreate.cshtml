@model EDInventory.Models.ViewModels.DepartmentViewModel
@{ ViewData["Title"] = "Nuevo Departamento"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-diagram-3 me-2"></i>Nuevo Departamento</h4>
    <a asp-action="Departments" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Volver</a>
</div>

<div class="card shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <form asp-action="DepartmentCreate" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="DepName" class="form-label fw-semibold"></label>
                <input asp-for="DepName" class="form-control" placeholder="Ej: Tecnologia de Informacion" />
                <span asp-validation-for="DepName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="SiteCode" class="form-label fw-semibold"></label>
                <select asp-for="SiteCode" asp-items="Model.Sites" class="form-select">
                    <option value="">-- Sin sede asignada --</option>
                </select>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
