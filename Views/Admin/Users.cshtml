@model IEnumerable<EDInventory.Models.Entities.User>
@{ ViewData["Title"] = "Usuarios del Sistema"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-badge me-2"></i>Usuarios del Sistema</h4>
    <div class="d-flex gap-2">
        <a asp-action="SystemRoles" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-shield-lock me-1"></i>Roles de Sistema
        </a>
        <a asp-action="UserCreate" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Usuario
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Usuario</th>
                    <th>Empleado</th>
                    <th>Rol de Sistema</th>
                    <th class="text-center">Estado</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var usr in Model)
                {
                    <tr>
                        <td>@usr.UserCode</td>
                        <td><i class="bi bi-person-circle me-1 text-muted"></i>@usr.UserLogin</td>
                        <td>@usr.Employee?.EmpSurname @usr.Employee?.EmpName</td>
                        <td>
                            <span class="badge bg-primary bg-opacity-75">@usr.UserRole?.UroleDesc</span>
                        </td>
                        <td class="text-center">
                            <span class="badge @(usr.Active ? "bg-success" : "bg-secondary")">
                                @(usr.Active ? "Activo" : "Inactivo")
                            </span>
                        </td>
                        <td class="text-center">
                            <a asp-action="UserEdit" asp-route-id="@usr.UserCode" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="UserToggle" asp-route-id="@usr.UserCode" method="post" data-confirm="¿Confirma el cambio de estado?" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm @(usr.Active ? "btn-outline-warning" : "btn-outline-success")"
                                        title="@(usr.Active ? "Desactivar" : "Activar")">
                                    <i class="bi @(usr.Active ? "bi-toggle-on" : "bi-toggle-off")"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No hay usuarios registrados.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
