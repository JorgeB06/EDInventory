@model EDInventory.Models.ViewModels.LicitacionViewModel
@{ ViewData["Title"] = "Editar Licitacion"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Editar Licitacion</h4>
    <a asp-controller="Gestion" asp-action="Licitaciones" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <form asp-controller="Gestion" asp-action="LicitacionEdit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="LicCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="LicNum" class="form-label fw-semibold"></label>
                <input asp-for="LicNum" class="form-control" />
                <span asp-validation-for="LicNum" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LicDesc" class="form-label fw-semibold"></label>
                <input asp-for="LicDesc" class="form-control" />
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="LicStart" class="form-label fw-semibold"></label>
                    <input asp-for="LicStart" class="form-control" type="date" />
                </div>
                <div class="col">
                    <label asp-for="LicEnd" class="form-label fw-semibold"></label>
                    <input asp-for="LicEnd" class="form-control" type="date" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="LicWarnDays" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <input asp-for="LicWarnDays" class="form-control" type="number" min="1" max="3650" />
                    <span class="input-group-text">dias</span>
                </div>
                <div class="form-text">Aviso previo al vencimiento. Por defecto: 180 dias (6 meses).</div>
                <span asp-validation-for="LicWarnDays" class="text-danger small"></span>
            </div>
            <hr class="my-3" />
            <div class="mb-2 form-check">
                <input asp-for="LicPostponed" class="form-check-input" type="checkbox" id="chkPostponed" />
                <label asp-for="LicPostponed" class="form-check-label fw-semibold text-warning">
                    <i class="bi bi-pause-circle me-1"></i>Marcar como aplazada
                </label>
                <div class="form-text">Indica que la licitacion vencio pero aun no se ha renovado.</div>
            </div>
            <div class="mb-3" id="divPostponedNote">
                <label asp-for="LicPostponedNote" class="form-label fw-semibold"></label>
                <input asp-for="LicPostponedNote" class="form-control" placeholder="Ej: pendiente de firma, en proceso de renovacion..." />
                <span asp-validation-for="LicPostponedNote" class="text-danger small"></span>
            </div>
            <hr class="my-3" />
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar cambios</button>
        </form>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const chk = document.getElementById('chkPostponed');
            const div = document.getElementById('divPostponedNote');
            function toggle() { div.style.display = chk.checked ? '' : 'none'; }
            toggle();
            chk.addEventListener('change', toggle);
        })();
    </script>
}
