@model EDInventory.Models.ViewModels.LicitacionViewModel
@{ ViewData["Title"] = "Nueva Licitacion"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Nueva Licitacion</h4>
    <a asp-controller="Gestion" asp-action="Licitaciones" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <form asp-controller="Gestion" asp-action="LicitacionCreate" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="LicNum" class="form-label fw-semibold"></label>
                <input asp-for="LicNum" class="form-control" placeholder="Ej: LIC-2024-001" />
                <span asp-validation-for="LicNum" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="LicDesc" class="form-label fw-semibold"></label>
                <input asp-for="LicDesc" class="form-control" placeholder="Ej: Licitacion equipos Hospital Nacional 2024" />
            </div>
            <div class="row mb-3">
                <div class="col">
                    <label asp-for="LicStart" class="form-label fw-semibold"></label>
                    <input asp-for="LicStart" class="form-control" type="date" />
                </div>
                <div class="col">
                    <label asp-for="LicEnd" class="form-label fw-semibold"></label>
                    <input asp-for="LicEnd" class="form-control" type="date" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="LicWarnDays" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <input asp-for="LicWarnDays" class="form-control" type="number" min="1" max="3650" />
                    <span class="input-group-text">dias</span>
                </div>
                <div class="form-text">Aviso previo al vencimiento. Por defecto: 180 dias (6 meses).</div>
                <span asp-validation-for="LicWarnDays" class="text-danger small"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
