@model EDInventory.Models.ViewModels.WarehouseViewModel
@{ ViewData["Title"] = "Editar Bodega"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-box-seam me-2"></i>Editar Bodega</h4>
    <a asp-controller="Gestion" asp-action="Warehouses" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:480px;">
    <div class="card-body">
        <form asp-controller="Gestion" asp-action="WarehouseEdit" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="WareCode" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>
            <div class="mb-3">
                <label asp-for="WareName" class="form-label fw-semibold"></label>
                <input asp-for="WareName" class="form-control" />
                <span asp-validation-for="WareName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="WareDesc" class="form-label fw-semibold"></label>
                <input asp-for="WareDesc" class="form-control" />
            </div>
            <div class="mb-4 form-check">
                <input asp-for="Active" class="form-check-input" type="checkbox" />
                <label asp-for="Active" class="form-check-label">Activo</label>
            </div>
            <button type="submit" class="btn btn-primary"><i class="bi bi-floppy me-1"></i>Guardar cambios</button>
        </form>
    </div>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
