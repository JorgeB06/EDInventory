@model EDInventory.Models.ViewModels.AuditReassignVM
@{
    ViewData["Title"] = $"Reasignar Auditoría #{Model.AuditCode}";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-person-fill-gear me-2"></i>Reasignar Auditoría</h4>
    <a asp-action="Detail" asp-route-id="@Model.AuditCode" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="card shadow-sm" style="max-width:500px;">
    <div class="card-header fw-bold">Datos de la Auditoría</div>
    <div class="card-body">
        <dl class="row mb-3">
            <dt class="col-sm-4">Código</dt>
            <dd class="col-sm-8">#@Model.AuditCode</dd>
            <dt class="col-sm-4">Alcance</dt>
            <dd class="col-sm-8">@Model.ScopeLabel</dd>
        </dl>
        <form asp-action="Reassign" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="AuditCode" />
            <div class="mb-3">
                <label asp-for="AssignedUserCode" class="form-label fw-semibold">Asignar a *</label>
                <select asp-for="AssignedUserCode" asp-items="Model.Users" class="form-select">
                    <option value="">— Seleccione usuario —</option>
                </select>
            </div>
            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Detail" asp-route-id="@Model.AuditCode" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Guardar
                </button>
            </div>
        </form>
    </div>
</div>
