@model EDInventory.Models.ViewModels.AuditSessionCreateVM
@{
    ViewData["Title"] = "Nueva Auditoría de Inventario";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-clipboard2-plus me-2"></i>Nueva Auditoría de Inventario</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="alert alert-info small">
    El usuario asignado ejecutará el conteo desde el módulo móvil. Si el conteo no coincide con el
    stock del sistema, la diferencia quedará pendiente de su aprobación antes de ajustar el inventario.
</div>

<div class="card shadow-sm" style="max-width:600px;">
    <div class="card-header fw-bold">Parámetros de la Auditoría</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="text-danger small mb-2"></div>

            <div class="mb-3">
                <label class="form-label fw-semibold">Alcance *</label>
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="AuditScope" value="CAJA" id="scopeCaja" checked>
                        <label class="form-check-label" for="scopeCaja"><i class="bi bi-box me-1"></i>Caja individual</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="AuditScope" value="LINEA" id="scopeLinea">
                        <label class="form-check-label" for="scopeLinea"><i class="bi bi-diagram-3 me-1"></i>Línea completa</label>
                    </div>
                </div>
            </div>

            <div class="mb-3" id="fieldBox">
                <label asp-for="BoxCode" class="form-label fw-semibold">Caja *</label>
                <select asp-for="BoxCode" asp-items="Model.Boxes" class="form-select">
                    <option value="">— Seleccione caja —</option>
                </select>
                <span asp-validation-for="BoxCode" class="text-danger small"></span>
            </div>

            <div class="mb-3 d-none" id="fieldLine">
                <label asp-for="LineCode" class="form-label fw-semibold">Línea *</label>
                <select asp-for="LineCode" asp-items="Model.Lines" class="form-select">
                    <option value="">— Seleccione línea —</option>
                </select>
                <span asp-validation-for="LineCode" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AssignedUserCode" class="form-label fw-semibold">Asignar a *</label>
                <select asp-for="AssignedUserCode" asp-items="Model.Users" class="form-select">
                    <option value="">— Seleccione usuario —</option>
                </select>
                <span asp-validation-for="AssignedUserCode" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Notes" class="form-label">Notas <span class="text-muted fw-normal">(opcional)</span></label>
                <textarea asp-for="Notes" class="form-control" rows="2" maxlength="300"></textarea>
            </div>

            <div class="d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Crear Auditoría
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const scopeRadios = document.querySelectorAll('input[name="AuditScope"]');
        const fieldBox  = document.getElementById('fieldBox');
        const fieldLine = document.getElementById('fieldLine');

        function toggleScope() {
            const scope = document.querySelector('input[name="AuditScope"]:checked').value;
            fieldBox.classList.toggle('d-none', scope !== 'CAJA');
            fieldLine.classList.toggle('d-none', scope !== 'LINEA');
        }
        scopeRadios.forEach(r => r.addEventListener('change', toggleScope));
        toggleScope();
    </script>
}
