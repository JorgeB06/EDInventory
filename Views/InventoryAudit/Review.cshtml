@model IEnumerable<EDInventory.Models.Entities.EngAuditPart>
@using EDInventory.Models.Entities
@{
    var session = (EngAuditSession)ViewBag.Session;
    ViewData["Title"] = $"Revisión — Auditoría #{session.AuditCode}";

    var conDiferencia = Model.Where(p => p.Variance != 0).ToList();
    var pendientes    = conDiferencia.Count(p => p.ResolutionStatus == "PENDIENTE");
    var sinDiferencia = Model.Count(p => p.Variance == 0);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2 text-warning"></i>Revisión de Discrepancias — Auditoría #@session.AuditCode</h4>
    <div class="d-flex gap-2">
        @if (pendientes > 0)
        {
            <form asp-action="ApproveAllPending" asp-route-auditCode="@session.AuditCode" method="post" data-confirm="¿Aprobar y aplicar los @pendientes ajuste(s) pendientes?">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-success btn-sm">
                    <i class="bi bi-check2-all me-1"></i>Aprobar todos (@pendientes)
                </button>
            </form>
        }
        <form asp-action="Close" asp-route-id="@session.AuditCode" method="post" data-confirm="¿Cerrar esta auditoría?">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-lock-fill me-1"></i>Cerrar Auditoría
            </button>
        </form>
        <a asp-action="Detail" asp-route-id="@session.AuditCode" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="d-flex gap-4 mb-3">
    <div><span class="badge bg-success fs-6">@sinDiferencia</span> <span class="text-muted small">sin diferencia</span></div>
    <div><span class="badge bg-warning text-dark fs-6">@pendientes</span> <span class="text-muted small">pendiente(s) de revisión</span></div>
    <div><span class="badge bg-secondary fs-6">@(Model.Count() - sinDiferencia - pendientes)</span> <span class="text-muted small">ya resuelto(s)</span></div>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-hourglass-split fs-1 d-block mb-2"></i>
        Aún no hay conteos registrados en esta auditoría.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Caja</th>
                        <th>Repuesto</th>
                        <th class="text-center">Sistema</th>
                        <th class="text-center">Contado</th>
                        <th class="text-center">Varianza</th>
                        <th>Estado</th>
                        <th style="width:230px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ap in Model)
                    {
                        bool hasVariance = ap.Variance != 0;
                        bool isPending   = ap.ResolutionStatus == "PENDIENTE";
                        <tr class="@(hasVariance && isPending ? "table-warning" : "")">
                            <td class="small text-muted">Caja @ap.AuditBox?.Box?.BoxNumber</td>
                            <td class="small">
                                @if (hasVariance && isPending)
                                {
                                    <i class="bi bi-exclamation-triangle-fill text-warning me-1" title="No coincide con el sistema"></i>
                                }
                                @ap.Part?.PartName
                                @if (!string.IsNullOrWhiteSpace(ap.Part?.PartRef))
                                {
                                    <span class="text-muted font-monospace"> (@ap.Part.PartRef)</span>
                                }
                            </td>
                            <td class="text-center">@ap.SystemQty</td>
                            <td class="text-center fw-semibold">@ap.CountedQty</td>
                            <td class="text-center fw-semibold @(ap.Variance > 0 ? "text-success" : ap.Variance < 0 ? "text-danger" : "text-muted")">
                                @(ap.Variance > 0 ? "+" : "")@ap.Variance
                            </td>
                            <td>
                                @switch (ap.ResolutionStatus)
                                {
                                    case "SIN_DIFERENCIA":
                                        <span class="badge bg-success"><i class="bi bi-check-lg me-1"></i>Coincide</span>
                                        break;
                                    case "APROBADO_AJUSTE":
                                        <span class="badge bg-primary"><i class="bi bi-arrow-repeat me-1"></i>Ajustado</span>
                                        break;
                                    case "RECHAZADO":
                                        <span class="badge bg-secondary"><i class="bi bi-x-lg me-1"></i>Descartado</span>
                                        break;
                                    default:
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                        break;
                                }
                            </td>
                            <td class="text-end">
                                @if (hasVariance && isPending)
                                {
                                    <form asp-action="ApproveAdjustment" asp-route-auditPartCode="@ap.AuditPartCode" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-success btn-sm py-0 px-1" title="Aprobar ajuste">
                                            <i class="bi bi-check-lg"></i>
                                        </button>
                                    </form>
                                    <form asp-action="RejectAdjustment" method="post" class="d-inline ms-1"
                                          onsubmit="return fillRejectNotes(this)">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="auditPartCode" value="@ap.AuditPartCode" />
                                        <input type="hidden" name="notes" />
                                        <button type="submit" class="btn btn-outline-secondary btn-sm py-0 px-1" title="Descartar diferencia">
                                            <i class="bi bi-x-lg"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@section Scripts {
    <script>
        function fillRejectNotes(form) {
            var notes = prompt('Motivo del descarte (opcional):', '');
            if (notes === null) return false; // canceló el prompt
            form.querySelector('input[name="notes"]').value = notes;
            return true;
        }
    </script>
}
