<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>@ViewData["Title"] - Móvil</title>
    <link rel="manifest" href="~/manifest.json" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        body { font-size: 1.1rem; background: #f2f2f2; padding-bottom: 1rem; }
        .btn-lg { font-size: 1.15rem; padding: .85rem 1rem; }
        .movil-topbar {
            background: #212529; color: #fff; padding: .75rem 1rem;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 1030;
        }
        .movil-topbar a { color: #fff; text-decoration: none; }
        .movil-container { padding: 1rem; max-width: 480px; margin: 0 auto; }
        .form-control, .form-select { font-size: 1.05rem; padding: .6rem .75rem; }
    </style>
</head>
<body>
    <div class="movil-topbar">
        <a asp-controller="Movil" asp-action="Index"><i class="bi bi-house-door-fill fs-5"></i></a>
        <span class="fw-bold">@ViewData["Title"]</span>
        <form asp-controller="Auth" asp-action="Logout" method="post" class="mb-0">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-link text-white p-0"><i class="bi bi-box-arrow-right fs-5"></i></button>
        </form>
    </div>

    <div class="movil-container">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["ScanError"] != null)
        {
            <div class="alert alert-warning alert-dismissible fade show">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>@TempData["ScanError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
