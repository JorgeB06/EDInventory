<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AssetCore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">
    @if (User.Identity?.IsAuthenticated == true)
    {
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Dashboard" asp-action="Index">
                    <img src="~/images/logo-diagnostika.png" alt="Diagnostika" style="height: 32px; object-fit: contain;" />
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navMenu">
                    @{
                        bool isAdmin    = User.IsInRole("Administrador");
                        bool isTiAny    = isAdmin || User.IsInRole("TI.Administrador") || User.IsInRole("TI.Tecnico") || User.IsInRole("TI.Consulta");
                        bool isTiWrite  = isAdmin || User.IsInRole("TI.Administrador") || User.IsInRole("TI.Tecnico");
                        bool isSvcAny   = isAdmin || User.IsInRole("Servicio.Administrador") || User.IsInRole("Servicio.Tecnico") || User.IsInRole("Servicio.Consulta");
                        bool isSvcWrite = isAdmin || User.IsInRole("Servicio.Administrador") || User.IsInRole("Servicio.Tecnico");
                        // Visibilidad cruzada: TI.Admin ve Servicio como consulta y viceversa
                        bool canSeeSvc  = isSvcAny || User.IsInRole("TI.Administrador");
                        bool canSeeTI   = isTiAny  || User.IsInRole("Servicio.Administrador");
                        // Gestión compartida: ambos admins de división + Admin global
                        bool canSeeGestion = isAdmin || User.IsInRole("TI.Administrador") || User.IsInRole("Servicio.Administrador")
                                             || User.IsInRole("TI.Tecnico") || User.IsInRole("TI.Consulta")
                                             || User.IsInRole("Servicio.Tecnico") || User.IsInRole("Servicio.Consulta");
                        bool isAdmManage   = isAdmin || User.IsInRole("TI.Administrador") || User.IsInRole("Servicio.Administrador");
                    }
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Dashboard" asp-action="Index">
                                <i class="bi bi-speedometer2 me-1"></i>Dashboard
                            </a>
                        </li>

                        @* ── MÓDULO TI ─────────────────────────────── *@
                        @if (canSeeTI)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-laptop me-1"></i>TI
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Equipment" asp-action="Index"><i class="bi bi-list-ul me-1"></i>Inventario</a></li>
                                    <li><a class="dropdown-item" asp-controller="Equipment" asp-action="MaintenanceDue"><i class="bi bi-wrench-adjustable me-1"></i>Mantenimientos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Incident" asp-action="Index" asp-route-entityType="TI"><i class="bi bi-tools me-1"></i>Incidentes</a></li>
                                    @if (isTiWrite)
                                    {
                                        <li><a class="dropdown-item" asp-controller="Equipment" asp-action="MovementStation"><i class="bi bi-upc-scan me-1"></i>Estación de Movimiento</a></li>
                                        <li><a class="dropdown-item" asp-controller="Equipment" asp-action="Create"><i class="bi bi-plus-circle me-1"></i>Nuevo Equipo</a></li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Dashboard" asp-action="Report"><i class="bi bi-printer me-1"></i>Reporte Completo</a></li>
                                </ul>
                            </li>
                        }

                        @* ── MÓDULO SERVICIO ───────────────────────── *@
                        @if (canSeeSvc)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-tools me-1"></i>Servicio
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Engineering" asp-action="Index"><i class="bi bi-box-seam me-1"></i>Repuestos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Engineering" asp-action="ScanBox"><i class="bi bi-upc-scan me-1"></i>Escanear Caja</a></li>
                                    <li><a class="dropdown-item" asp-controller="Engineering" asp-action="Search"><i class="bi bi-search me-1"></i>Buscar Repuesto</a></li>
                                    <li><a class="dropdown-item" asp-controller="Engineering" asp-action="AssetsOnSite"><i class="bi bi-hospital me-1"></i>Activos en Sitio</a></li>
                                    <li><a class="dropdown-item" asp-controller="Engineering" asp-action="MaintenanceDue"><i class="bi bi-wrench-adjustable me-1"></i>Mantenimientos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Incident" asp-action="Index" asp-route-entityType="SVC"><i class="bi bi-tools me-1"></i>Incidentes</a></li>
                                    <li><a class="dropdown-item" asp-controller="Calibration" asp-action="Index"><i class="bi bi-rulers me-1"></i>Calibraciones</a></li>
                                    @if (isSvcWrite)
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" asp-controller="Engineering" asp-action="LineCreate"><i class="bi bi-plus-circle me-1"></i>Nueva Línea</a></li>
                                    }
                                </ul>
                            </li>
                        }

                        @* ── GESTIÓN COMPARTIDA ────────────────────── *@
                        @if (canSeeGestion)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-building me-1"></i>Gestión
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Hospital" asp-action="Index"><i class="bi bi-hospital me-1"></i>Hospitales</a></li>
                                    <li><a class="dropdown-item" asp-controller="Gestion" asp-action="Licitaciones"><i class="bi bi-file-earmark-text me-1"></i>Licitaciones</a></li>
                                    <li><a class="dropdown-item" asp-controller="Gestion" asp-action="Warehouses"><i class="bi bi-box-seam me-1"></i>Bodegas</a></li>
                                </ul>
                            </li>
                        }

                        @* ── ADMINISTRACIÓN (global admin) ──────────── *@
                        @if (isAdmin)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                    <i class="bi bi-gear me-1"></i>Administracion
                                </a>
                                <ul class="dropdown-menu">
                                    <li><a class="dropdown-item" asp-controller="Catalog" asp-action="DocumentTypes">Tipos de Documento</a></li>
                                    <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Companies">Empresas</a></li>
                                    <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Sites">Sedes</a></li>
                                    <li><a class="dropdown-item" asp-controller="Catalog" asp-action="Brands">Marcas y Modelos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Catalog" asp-action="AssetTypes">Tipos de Activo</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Departments"><i class="bi bi-diagram-3 me-1"></i>Departamentos</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Positions"><i class="bi bi-person-badge me-1"></i>Puestos</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Users"><i class="bi bi-people me-1"></i>Usuarios</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Employees"><i class="bi bi-person-lines-fill me-1"></i>Empleados</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="SystemRoles"><i class="bi bi-shield-lock me-1"></i>Roles de Sistema</a></li>
                                </ul>
                            </li>
                        }
                    </ul>
                    <ul class="navbar-nav align-items-center">
                        @if (isTiAny || canSeeSvc)
                        {
                            <li class="nav-item me-1">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Search" title="Busqueda Global">
                                    <i class="bi bi-search" style="font-size:1.15rem;"></i>
                                </a>
                            </li>
                            <li class="nav-item me-1">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="Workload" title="Carga de Tecnicos">
                                    <i class="bi bi-person-workspace" style="font-size:1.15rem;"></i>
                                </a>
                            </li>
                            <li class="nav-item me-1">
                                <a class="nav-link" asp-controller="Dashboard" asp-action="ExportPdf" title="Descargar PDF" target="_blank">
                                    <i class="bi bi-file-earmark-pdf" style="font-size:1.15rem;"></i>
                                </a>
                            </li>
                        }
                        <li class="nav-item me-1">
                            <button type="button" class="nav-link btn btn-link px-2 py-1"
                                    data-bs-toggle="modal" data-bs-target="#helpModal"
                                    title="Ayuda de esta página"
                                    style="opacity:.8; line-height:1;">
                                <i class="bi bi-question-circle-fill" style="font-size:1.15rem;"></i>
                            </button>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Auth" asp-action="ChangePassword">
                                        <i class="bi bi-key me-1"></i>Cambiar contraseña
                                    </a>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Auth" asp-action="Logout" method="post">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-1"></i>Cerrar sesion
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <!-- ── Modal de Ayuda Contextual ─────────────────────────────── -->
        <div class="modal fade" id="helpModal" tabindex="-1" aria-labelledby="helpModalLabel" aria-hidden="true">
          <div class="modal-dialog modal-lg modal-dialog-scrollable">
            <div class="modal-content">
              <div class="modal-header bg-dark text-white py-2">
                <h5 class="modal-title d-flex align-items-center gap-2" id="helpModalLabel">
                  <i class="bi bi-question-circle fs-5"></i>
                  <span id="helpModalTitle">Ayuda</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
              </div>
              <div class="modal-body py-3" id="helpModalBody">
                <p class="text-muted">Cargando...</p>
              </div>
              <div class="modal-footer py-2">
                <small class="text-muted me-auto">
                  <i class="bi bi-info-circle me-1"></i>EDInventory — Ayuda contextual v1.1
                </small>
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                  <i class="bi bi-x-lg me-1"></i>Cerrar
                </button>
              </div>
            </div>
          </div>
        </div>

        <div class="container-fluid mt-3 flex-grow-1">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>

        <footer class="bg-dark text-white-50 text-center small py-2 mt-4">
            Departamento de Ingenieria &mdash; Diagnostika S.A. &copy; @DateTime.Now.Year
        </footer>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Rol del usuario actual (evaluado en servidor)
        const isTecnico = @Json.Serialize(User.IsInRole("TI.Tecnico") || User.IsInRole("Servicio.Tecnico"));

        document.addEventListener('DOMContentLoaded', function () {
            // Confirmacion en formularios marcados con data-confirm (borrados, toggles)
            document.querySelectorAll('form[data-confirm]').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    if (!confirm(form.dataset.confirm)) e.preventDefault();
                });
            });

            // Confirmacion de edicion para Tecnicos (formularios marcados con class "tecnico-confirm")
            if (isTecnico) {
                document.querySelectorAll('form.tecnico-confirm').forEach(function (form) {
                    form.addEventListener('submit', function (e) {
                        if (!confirm('Atencion: esta modificando un registro existente. ¿Confirma guardar los cambios?')) {
                            e.preventDefault();
                        }
                    });
                });
            }
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)

