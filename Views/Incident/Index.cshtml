@model IEnumerable<EDInventory.Models.Entities.Incident>
@{
    ViewData["Title"] = "Incidentes";
    bool canWrite = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.TiAdmin) || User.IsInRole(AppRoles.SvcAdmin);
    string? entityType = ViewBag.EntityType as string;
    string? status     = ViewBag.Status     as string;
    string? priority   = ViewBag.Priority   as string;
    int page       = ViewBag.Page;
    int totalPages = ViewBag.TotalPages;
    int total      = ViewBag.Total;

    string PriBadge(string p) => p switch {
        "CRITICA" => "bg-danger",
        "ALTA"    => "bg-warning text-dark",
        "MEDIA"   => "bg-info text-dark",
        _         => "bg-secondary"
    };
    string StBadge(string s) => s switch {
        "CERRADA"    => "bg-success",
        "CANCELADA"  => "bg-secondary",
        "EN_PROCESO" => "bg-warning text-dark",
        _            => "bg-primary"
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-tools me-2"></i>Incidentes y Reparaciones</h4>
    @if (canWrite)
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Nuevo Incidente
        </a>
    }
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select name="entityType" class="form-select form-select-sm">
            <option value="">Division (todas)</option>
            <option value="TI"  selected="@(entityType == "TI")">TI</option>
            <option value="SVC" selected="@(entityType == "SVC")">Servicio</option>
        </select>
    </div>
    <div class="col-auto">
        <select name="status" class="form-select form-select-sm">
            <option value="">Estado (todos)</option>
            <option value="ABIERTA"    selected="@(status == "ABIERTA")">Abierta</option>
            <option value="EN_PROCESO" selected="@(status == "EN_PROCESO")">En Proceso</option>
            <option value="CERRADA"    selected="@(status == "CERRADA")">Cerrada</option>
            <option value="CANCELADA"  selected="@(status == "CANCELADA")">Cancelada</option>
        </select>
    </div>
    <div class="col-auto">
        <select name="priority" class="form-select form-select-sm">
            <option value="">Prioridad (todas)</option>
            <option value="CRITICA" selected="@(priority == "CRITICA")">Critica</option>
            <option value="ALTA"    selected="@(priority == "ALTA")">Alta</option>
            <option value="MEDIA"   selected="@(priority == "MEDIA")">Media</option>
            <option value="BAJA"    selected="@(priority == "BAJA")">Baja</option>
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary btn-sm">Filtrar</button>
    </div>
</form>

<div class="text-muted small mb-2">@total incidente(s)</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
        No hay incidentes registrados.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead class="table-dark">
                <tr>
                    <th>#</th><th>Div.</th><th>Equipo / Activo</th><th>Titulo</th>
                    <th>Tipo</th><th>Prioridad</th><th>Estado</th><th>Fecha</th><th>Asignado</th><th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in Model)
                {
                    var entityName = i.EntityType == "TI"
                        ? i.ItEquip?.ItequipDesc
                        : i.EngAsset?.AssetDesc;
                    var assigneeName = i.Assignee?.Employee != null
                        ? $"{i.Assignee.Employee.EmpName} {i.Assignee.Employee.EmpSurname}"
                        : i.Assignee?.UserLogin ?? "—";
                    <tr>
                        <td class="text-muted small">@i.IncidentCode</td>
                        <td><span class="badge @(i.EntityType == "TI" ? "bg-primary" : "bg-success")">@i.EntityType</span></td>
                        <td class="small">@(entityName ?? "—")</td>
                        <td class="small fw-semibold">@i.IncidentTitle</td>
                        <td class="small">@i.IncidentType</td>
                        <td><span class="badge @PriBadge(i.IncidentPriority)">@i.IncidentPriority</span></td>
                        <td><span class="badge @StBadge(i.IncidentStatus)">@i.IncidentStatus</span></td>
                        <td class="small text-nowrap">@i.IncidentDate.ToString("dd/MM/yyyy")</td>
                        <td class="small">@assigneeName</td>
                        <td>
                            <a asp-action="Detail" asp-route-id="@i.IncidentCode" class="btn btn-outline-primary btn-sm py-0 px-1">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (totalPages > 1)
    {
        <nav>
            <ul class="pagination pagination-sm">
                @for (int p = 1; p <= totalPages; p++)
                {
                    <li class="page-item @(p == page ? "active" : "")">
                        <a class="page-link" asp-action="Index"
                           asp-route-entityType="@entityType"
                           asp-route-status="@status"
                           asp-route-priority="@priority"
                           asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
