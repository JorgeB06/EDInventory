@model EDInventory.Models.ViewModels.MovilWithdrawVM
@{
    ViewData["Title"] = "Movimiento Rápido";
    bool needsConfirm = (bool)(ViewBag.NeedsConfirm ?? false);
    int resultingQty = (int)(ViewBag.ResultingQty ?? 0);
}

<div class="mb-3">
    <h5 class="mb-1"><i class="bi bi-box-arrow-right me-2 text-warning"></i>@Model.PartName</h5>
    @if (!string.IsNullOrWhiteSpace(Model.PartRef))
    {
        <div class="text-muted small font-monospace">@Model.PartRef</div>
    }
    <span class="badge @(Model.CurrentQty == 0 ? "bg-danger" : Model.CurrentQty <= 2 ? "bg-warning text-dark" : "bg-success") fs-6 mt-1">
        Stock actual: @Model.CurrentQty
    </span>
</div>

@if (needsConfirm)
{
    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle-fill me-1"></i>
        Esta acción dejará el stock en <strong>@resultingQty</strong> unidad(es). ¿Confirma continuar?
    </div>
}

<form asp-action="RetiroRapidoPart" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PartCode" />
    <input type="hidden" asp-for="BoxCode" />
    <input type="hidden" name="Confirmado" id="confirmadoField" value="false" />

    <div class="mb-3">
        <label class="form-label fw-semibold">Tipo de movimiento</label>
        <div class="d-flex gap-3">
            <div class="form-check">
                <input class="form-check-input" type="radio" asp-for="MovType" value="RETIRO" id="chkRetiro">
                <label class="form-check-label text-danger fw-semibold" for="chkRetiro">
                    <i class="bi bi-box-arrow-right me-1"></i>Retiro
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" asp-for="MovType" value="DEVOLUCION" id="chkDevol">
                <label class="form-check-label text-success fw-semibold" for="chkDevol">
                    <i class="bi bi-box-arrow-in-left me-1"></i>Devolución
                </label>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="Qty" class="form-label fw-semibold">Cantidad</label>
        <input asp-for="Qty" type="number" min="1" inputmode="numeric" class="form-control form-control-lg" />
        <span asp-validation-for="Qty" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="HospCode" class="form-label fw-semibold">Hospital destino <span class="text-muted fw-normal">(opcional)</span></label>
        <select asp-for="HospCode" asp-items="Model.Hospitals" class="form-select">
            <option value="">-- Sin especificar --</option>
        </select>
    </div>

    <div class="mb-4">
        <label asp-for="Notes" class="form-label fw-semibold">Notas <span class="text-muted fw-normal">(opcional)</span></label>
        <textarea asp-for="Notes" class="form-control" rows="2" maxlength="200"></textarea>
    </div>

    @if (needsConfirm)
    {
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-warning btn-lg" onclick="document.getElementById('confirmadoField').value='true';">
                <i class="bi bi-check-lg me-2"></i>Sí, confirmar
            </button>
            <a asp-action="RetiroRapido" asp-route-boxCode="@Model.BoxCode" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    }
    else
    {
        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-primary btn-lg">
                <i class="bi bi-check-lg me-2"></i>Registrar
            </button>
            <a asp-action="RetiroRapido" asp-route-boxCode="@Model.BoxCode" class="btn btn-outline-secondary">Cancelar</a>
        </div>
    }
</form>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
