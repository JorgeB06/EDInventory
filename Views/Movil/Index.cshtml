@{
    ViewData["Title"] = "Móvil";
}

<div class="text-center mb-4 mt-3">
    <i class="bi bi-phone fs-1 text-primary"></i>
    <h5 class="fw-bold mt-2 mb-0">EDInventory Móvil</h5>
    <p class="text-muted small">Auditoría de inventario y movimientos rápidos de repuestos</p>
</div>

<div class="d-grid gap-3">
    <a asp-action="Scan" class="btn btn-primary btn-lg py-3">
        <i class="bi bi-upc-scan me-2"></i>Escanear Caja
    </a>
    <a asp-action="MisAuditorias" class="btn btn-outline-primary btn-lg py-3">
        <i class="bi bi-clipboard2-check me-2"></i>Mis Auditorías
    </a>
</div>
