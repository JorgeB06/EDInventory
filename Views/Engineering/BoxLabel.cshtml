@model EDInventory.Models.Entities.EngBox
@{
    ViewData["Title"] = "Etiqueta - Caja " + Model.BoxNumber;
    Layout = null;

    var company  = ViewBag.Company as EDInventory.Models.Entities.Company;
    var parts    = Model.Parts.OrderBy(p => p.PartRef ?? p.PartName).ToList();
    var hasCodes = parts.Any(p => !string.IsNullOrWhiteSpace(p.PartRef));
    var barcodeVal = $"ENG{Model.BoxCode:D6}";

    string ubicacion = Model.Warehouse != null
        ? Model.Warehouse.WareName
            + (!string.IsNullOrWhiteSpace(Model.WareRack)    ? $" / Rack {Model.WareRack}"    : "")
            + (!string.IsNullOrWhiteSpace(Model.WareEstante) ? $" / Est. {Model.WareEstante}" : "")
        : "Sin ubicación";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>Etiqueta — Caja @Model.BoxNumber</title>
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.6/dist/JsBarcode.all.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        @@page {
            size: 4in 4in;
            margin: 0;
        }

        body {
            font-family: Arial, sans-serif;
            background: #e8e8e8;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 24px;
            gap: 16px;
        }

        .controls {
            display: flex;
            gap: 10px;
            align-items: center;
            background: white;
            padding: 10px 20px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,.18);
            flex-wrap: wrap;
        }
        .controls button {
            padding: 8px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-size: 14px;
            font-weight: bold;
        }
        .btn-print { background: #0d6efd; color: white; }
        .btn-back  { background: #6c757d; color: white; }
        .controls span { font-size: 12px; color: #666; }

        .label-preview {
            background: white;
            border-radius: 6px;
            box-shadow: 0 3px 12px rgba(0,0,0,.22);
            padding: 6px;
        }

        .label {
            width: 4in;
            height: 4in;
            background: white;
            border: 2px solid #111;
            display: flex;
            flex-direction: column;
            padding: 5mm;
            overflow: hidden;
        }

        .lbl-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid #111;
            padding-bottom: 3mm;
            margin-bottom: 3mm;
        }
        .lbl-company {
            font-size: 13pt;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: .5px;
            line-height: 1.2;
        }
        .lbl-tag {
            background: #111;
            color: white;
            font-size: 8pt;
            font-weight: bold;
            padding: 2px 7px;
            border-radius: 3px;
            white-space: nowrap;
        }

        .lbl-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 2mm 5mm;
            margin-bottom: 3mm;
        }
        .lbl-field { line-height: 1.5; }
        .lbl-field.span2 { grid-column: 1 / -1; }
        .lbl-field .f-lbl {
            font-size: 7pt;
            font-weight: 700;
            color: #444;
            text-transform: uppercase;
            letter-spacing: .4px;
        }
        .lbl-field .f-val {
            font-size: 10pt;
            font-weight: 700;
            word-break: break-word;
        }
        .lbl-field.span2 .f-val { font-size: 9pt; }

        /* Sección de códigos internos */
        .codes-section {
            flex: 1;
            overflow: hidden;
        }
        .codes-lbl {
            font-size: 7pt;
            font-weight: 700;
            color: #444;
            text-transform: uppercase;
            letter-spacing: .4px;
            margin-bottom: 1.5mm;
        }
        .codes-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 1.5mm;
        }
        .code-chip {
            font-size: 7.5pt;
            font-family: 'Courier New', monospace;
            font-weight: bold;
            background: #f0f0f0;
            border: 1px solid #ccc;
            border-radius: 3px;
            padding: 1px 4px;
            white-space: nowrap;
        }
        .codes-empty {
            font-size: 8pt;
            color: #999;
            font-style: italic;
        }

        .lbl-divider {
            border: none;
            border-top: 2px solid #888;
            margin: 2mm 0;
        }

        .lbl-barcode {
            display: flex;
            flex-direction: column;
            align-items: center;
            margin-top: auto;
        }
        .lbl-barcode svg {
            width: 3.6in;
            height: auto;
        }
        .lbl-barcode .sn {
            font-family: 'Courier New', monospace;
            font-size: 8pt;
            font-weight: 700;
            letter-spacing: 1px;
            margin-top: 1mm;
        }

        @@media print {
            body           { background: white; padding: 0; gap: 0; }
            .controls      { display: none !important; }
            .label-preview { box-shadow: none; padding: 0; border-radius: 0; }
            .label         { border: 1.5pt solid #000; width: 4in; height: 4in; }
            *              { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        }
    </style>
</head>
<body>

<div class="controls">
    <button class="btn-print" onclick="window.print()">&#128438;&nbsp; Imprimir etiqueta</button>
    <button class="btn-back"  onclick="window.close()">&#8592;&nbsp; Cerrar</button>
    <span>Formato: 4 &times; 4 pulgadas &mdash; Zebra GK420D</span>
</div>

<div class="label-preview">
<div class="label">

    <div class="lbl-header">
        <div class="lbl-company">@(company?.CompanyName ?? "Departamento Servicio")</div>
        <div class="lbl-tag">Servicio &nbsp;/&nbsp; Ingeniería</div>
    </div>

    <div class="lbl-grid">
        <div class="lbl-field">
            <div class="f-lbl">Línea</div>
            <div class="f-val">@(Model.Line?.LineName ?? "—")</div>
        </div>
        <div class="lbl-field">
            <div class="f-lbl">Número de caja</div>
            <div class="f-val">@Model.BoxNumber</div>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.BoxDesc))
        {
            <div class="lbl-field span2">
                <div class="f-lbl">Descripción</div>
                <div class="f-val" style="font-size:8.5pt">@Model.BoxDesc</div>
            </div>
        }
        @if (Model.Warehouse != null)
        {
            <div class="lbl-field span2">
                <div class="f-lbl">Ubicación</div>
                <div class="f-val" style="font-size:8.5pt">@ubicacion</div>
            </div>
        }
    </div>

    <div class="codes-section">
        <div class="codes-lbl">Códigos internos (@parts.Count @(parts.Count == 1 ? "ítem" : "ítems"))</div>
        @if (hasCodes)
        {
            <div class="codes-grid">
                @foreach (var p in parts.Where(p => !string.IsNullOrWhiteSpace(p.PartRef)))
                {
                    <span class="code-chip">@p.PartRef</span>
                }
            </div>
        }
        else
        {
            <div class="codes-empty">Sin códigos internos registrados</div>
        }
    </div>

    <hr class="lbl-divider" />
    <div class="lbl-barcode">
        <svg id="barcode"></svg>
        <div class="sn">@barcodeVal</div>
    </div>

</div>
</div>

<script>
    JsBarcode("#barcode", "@barcodeVal", {
        format: "CODE128",
        width: 2.2,
        height: 45,
        displayValue: false,
        margin: 0
    });
</script>

</body>
</html>
