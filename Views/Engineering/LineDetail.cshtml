@model EDInventory.Models.Entities.EngLine
@{
    ViewData["Title"] = $"Línea {Model.LineName}";
    var search = ViewBag.Search as string;
    bool canWrite  = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.SvcAdmin) || User.IsInRole(AppRoles.SvcTecnico);
    bool canManage = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.SvcAdmin);
}

<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm me-2">
            <i class="bi bi-arrow-left"></i>
        </a>
        <h4 class="d-inline mb-0">
            <i class="bi bi-diagram-2 me-2 text-primary"></i>Línea @Model.LineName
            @if (!string.IsNullOrWhiteSpace(Model.LineGroup))
            {
                <small class="text-muted fs-6">— @Model.LineGroup</small>
            }
        </h4>
    </div>
    @if (canWrite)
    {
        <a asp-action="BoxCreate" asp-route-lineCode="@Model.LineCode" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle me-1"></i>Nueva Caja
        </a>
    }
</div>

<!-- Búsqueda -->
<form asp-action="LineDetail" asp-route-id="@Model.LineCode" method="get" class="mb-3">
    <div class="input-group input-group-sm" style="max-width: 400px;">
        <input type="text" name="search" value="@search" class="form-control" placeholder="Buscar código o repuesto..." />
        <button class="btn btn-outline-primary" type="submit"><i class="bi bi-search"></i></button>
        @if (!string.IsNullOrWhiteSpace(search))
        {
            <a asp-action="LineDetail" asp-route-id="@Model.LineCode" class="btn btn-outline-secondary">
                <i class="bi bi-x"></i>
            </a>
        }
    </div>
</form>

@if (!Model.Boxes.Any())
{
    <div class="alert alert-info">
        Esta línea no tiene cajas registradas.
        @if (canWrite)
        {
            <a asp-action="BoxCreate" asp-route-lineCode="@Model.LineCode">Agregar primera caja</a>
        }
    </div>
}
else
{
    <div class="accordion" id="boxAccordion">
        @foreach (var box in Model.Boxes.OrderBy(b => b.BoxNumber))
        {
            var collapseId = $"box{box.BoxCode}";
            var hasResults = box.Parts.Any();

            <div class="accordion-item mb-2 border shadow-sm @(!box.Active ? "opacity-50" : "")">
                <h2 class="accordion-header">
                    <button class="accordion-button @(hasResults || string.IsNullOrWhiteSpace(search) ? "" : "collapsed")"
                            type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                        <span class="fw-bold me-2">Caja @box.BoxNumber</span>
                        @if (!string.IsNullOrWhiteSpace(box.BoxDesc))
                        {
                            <span class="text-muted me-3">— @box.BoxDesc</span>
                        }
                        <span class="badge bg-primary ms-auto me-3">@box.Parts.Count ítems</span>
                        <span class="badge bg-success me-2">@box.Parts.Sum(p => p.PartQty) uds</span>
                    </button>
                </h2>
                <div id="@collapseId" class="accordion-collapse collapse @(string.IsNullOrWhiteSpace(search) ? "" : (hasResults ? "show" : ""))">
                    <div class="accordion-body p-0">
                        @if (!box.Parts.Any())
                        {
                            <p class="text-muted p-3 mb-0">
                                Sin repuestos.
                                @if (canWrite)
                                {
                                    <a asp-action="PartCreate" asp-route-boxCode="@box.BoxCode">Agregar repuesto</a>
                                }
                            </p>
                        }
                        else
                        {
                            <table class="table table-sm table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Cód. Interno</th>
                                        <th>Parte Fab.</th>
                                        <th>Repuesto</th>
                                        <th class="text-center">Cant.</th>
                                        <th>Notas</th>
                                        <th style="width:80px"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var part in box.Parts.OrderBy(p => p.PartRef))
                                    {
                                        <tr>
                                            <td class="font-monospace small">@part.PartRef</td>
                                            <td class="font-monospace small text-primary">@part.PartMfrRef</td>
                                            <td>@part.PartName</td>
                                            <td class="text-center">
                                                <span class="badge @(part.PartQty == 0 ? "bg-danger" : part.PartQty <= 2 ? "bg-warning text-dark" : "bg-success")">
                                                    @part.PartQty
                                                </span>
                                            </td>
                                            <td class="text-muted small">@part.PartNotes</td>
                                            <td class="text-end">
                                                @if (canWrite)
                                                {
                                                    <a asp-action="PartEdit" asp-route-id="@part.PartCode"
                                                       class="btn btn-outline-primary btn-sm py-0 px-1" title="Editar">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                }
                                                @if (canManage)
                                                {
                                                    <form asp-action="PartDelete" asp-route-id="@part.PartCode"
                                                          method="post" class="d-inline"
                                                          data-confirm="¿Eliminar repuesto '@part.PartName'?">
                                                        @Html.AntiForgeryToken()
                                                        <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Eliminar">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                        <div class="px-3 py-2 border-top d-flex gap-2 flex-wrap">
                            @if (canWrite)
                            {
                                <a asp-action="PartCreate" asp-route-boxCode="@box.BoxCode" class="btn btn-outline-success btn-sm">
                                    <i class="bi bi-plus me-1"></i>Agregar repuesto
                                </a>
                            }
                            <a asp-action="BoxLabel" asp-route-id="@box.BoxCode" target="_blank" class="btn btn-outline-dark btn-sm">
                                <i class="bi bi-tag me-1"></i>Imprimir Etiqueta
                            </a>
                            @if (canWrite)
                            {
                                <a asp-action="BoxEdit" asp-route-id="@box.BoxCode" class="btn btn-outline-secondary btn-sm">
                                    <i class="bi bi-pencil me-1"></i>Editar caja
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
