@model EDInventory.Models.Entities.EngPart
@{
    ViewData["Title"] = "Agregar Repuesto";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Agregar Repuesto
                    <small class="text-muted">— Línea @ViewBag.LineName / Caja @ViewBag.BoxNumber</small>
                </h5>
            </div>
            <div class="card-body">
                <form asp-action="PartCreate" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="BoxCode" type="hidden" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Código interno</label>
                        <input asp-for="PartRef" class="form-control font-monospace" placeholder="Ej: D09569" />
                        <div class="form-text">Referencia interna de la empresa.</div>
                        <span asp-validation-for="PartRef" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Parte fabricante</label>
                        <input asp-for="PartMfrRef" class="form-control font-monospace" placeholder="Ej: 453564048271" />
                        <div class="form-text">Número de parte del fabricante del equipo.</div>
                        <span asp-validation-for="PartMfrRef" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre del repuesto <span class="text-danger">*</span></label>
                        <input asp-for="PartName" class="form-control" placeholder="Nombre descriptivo del repuesto" />
                        <span asp-validation-for="PartName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Cantidad <span class="text-danger">*</span></label>
                        <input asp-for="PartQty" class="form-control" type="number" min="0" value="1" />
                        <span asp-validation-for="PartQty" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-semibold">Notas</label>
                        <input asp-for="PartNotes" class="form-control" placeholder="Observaciones opcionales" />
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Guardar
                        </button>
                        <a asp-action="LineDetail" asp-route-id="@ViewBag.LineCode" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
