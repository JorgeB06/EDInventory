@model EDInventory.Models.Entities.EngPart
@using EDInventory.Models.Entities
@{
    ViewData["Title"] = "Historial de Repuesto";
    var movements = ViewBag.Movements as List<EngPartMovement> ?? new List<EngPartMovement>();
    var totalRetiros    = movements.Where(m => m.MovType == "RETIRO").Sum(m => Math.Abs(m.MovQty));
    var totalDevoluc    = movements.Where(m => m.MovType == "DEVOLUCION").Sum(m => m.MovQty);
}

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="BoxDetail" asp-route-id="@Model.BoxCode" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="bi bi-clock-history me-2 text-primary"></i>Historial de Repuesto</h4>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted mb-2"><i class="bi bi-info-circle me-1"></i>Información</h6>
                <div class="fw-bold fs-5 mb-1">@Model.PartName</div>
                @if (!string.IsNullOrWhiteSpace(Model.PartRef))
                {
                    <div class="text-muted small font-monospace mb-1">Interno: @Model.PartRef</div>
                }
                @if (!string.IsNullOrWhiteSpace(Model.PartMfrRef))
                {
                    <div class="text-muted small font-monospace mb-1">Fab: @Model.PartMfrRef</div>
                }
                <div class="mt-2">
                    <span class="text-muted small">Línea: </span>
                    <span class="fw-semibold small">@Model.Box?.Line?.LineName</span>
                    <span class="text-muted small ms-2">· Caja @Model.Box?.BoxNumber</span>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-7">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h6 class="text-muted mb-3"><i class="bi bi-bar-chart me-1"></i>Resumen de movimientos</h6>
                <div class="d-flex gap-4">
                    <div class="text-center">
                        <div class="fs-4 fw-bold @(Model.PartQty == 0 ? "text-danger" : Model.PartQty <= 2 ? "text-warning" : "text-success")">
                            @Model.PartQty
                        </div>
                        <div class="small text-muted">Stock actual</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-danger">@totalRetiros</div>
                        <div class="small text-muted">Total retirado</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-success">@totalDevoluc</div>
                        <div class="small text-muted">Total devuelto</div>
                    </div>
                    <div class="text-center">
                        <div class="fs-4 fw-bold text-secondary">@movements.Count</div>
                        <div class="small text-muted">Movimientos</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (!movements.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
        Sin movimientos registrados para este repuesto.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-header">
            <h6 class="mb-0"><i class="bi bi-list-ul me-1"></i>Movimientos (@movements.Count)</h6>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th class="text-center">Cantidad</th>
                        <th class="text-center">Stock tras</th>
                        <th>Hospital</th>
                        <th>Usuario</th>
                        <th>Notas</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var m in movements)
                    {
                        <tr>
                            <td class="small">@m.MovDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (m.MovType == "RETIRO")
                                {
                                    <span class="badge bg-warning text-dark">
                                        <i class="bi bi-box-arrow-right me-1"></i>Retiro
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        <i class="bi bi-box-arrow-in-left me-1"></i>Devolución
                                    </span>
                                }
                            </td>
                            <td class="text-center fw-semibold @(m.MovQty < 0 ? "text-danger" : "text-success")">
                                @(m.MovQty > 0 ? "+" : "")@m.MovQty
                            </td>
                            <td class="text-center">
                                <span class="badge @(m.PartQtyAfter == 0 ? "bg-danger" : m.PartQtyAfter <= 2 ? "bg-warning text-dark" : "bg-secondary")">
                                    @m.PartQtyAfter
                                </span>
                            </td>
                            <td class="small">@(m.Hospital?.HospName ?? "—")</td>
                            <td class="small">
                                @(m.User?.Employee != null
                                    ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}"
                                    : m.User?.UserLogin ?? "—")
                            </td>
                            <td class="small text-muted">@(m.MovNotes ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
