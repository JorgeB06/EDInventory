@{
    ViewData["Title"] = "Importar Repuestos";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-file-earmark-arrow-up me-2"></i>Importar Repuestos</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<div class="row">
    <div class="col-lg-7">

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-1-circle me-1 text-primary"></i>Descarga la plantilla
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Usa este archivo Excel como base. Cada fila representa un repuesto.<br>
                    Las líneas y cajas se crean automáticamente si no existen.
                    Los repuestos con el mismo <strong>REPUESTO_REF</strong> en la misma caja se omiten.
                </p>
                <a asp-action="ImportTemplate" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-download me-1"></i>Descargar plantilla.xlsx
                </a>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-header bg-light fw-semibold">
                <i class="bi bi-2-circle me-1 text-primary"></i>Sube el archivo completado
            </div>
            <div class="card-body">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@e.ErrorMessage</div>
                        }
                    </div>
                }

                <form method="post" enctype="multipart/form-data" asp-action="Import">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Archivo Excel (.xlsx)</label>
                        <input type="file" name="file" accept=".xlsx" class="form-control" required />
                        <div class="form-text">Tamaño máximo recomendado: 5 MB.</div>
                    </div>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-upload me-1"></i>Importar
                    </button>
                </form>
            </div>
        </div>

    </div>

    <div class="col-lg-5 mt-4 mt-lg-0">
        <div class="card border-0 bg-light">
            <div class="card-body">
                <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-1"></i>Columnas de la plantilla</h6>
                <table class="table table-sm table-bordered mb-0 small">
                    <thead class="table-primary">
                        <tr>
                            <th>Columna</th>
                            <th>Obligatorio</th>
                            <th>Descripción</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>LINEA_GRUPO</td><td>No</td><td>Agrupador de líneas (ej. PHILIPS)</td></tr>
                        <tr><td>LINEA_NOMBRE</td><td><strong>Sí</strong></td><td>Nombre de la línea de equipo</td></tr>
                        <tr><td>CAJA_NUMERO</td><td><strong>Sí</strong></td><td>Número entero positivo</td></tr>
                        <tr><td>CAJA_DESC</td><td>No</td><td>Descripción de la caja</td></tr>
                        <tr><td>REPUESTO_REF</td><td>No</td><td>Código/referencia del repuesto</td></tr>
                        <tr><td>REPUESTO_NOMBRE</td><td><strong>Sí</strong></td><td>Nombre del repuesto</td></tr>
                        <tr><td>CANTIDAD</td><td>No</td><td>Stock actual (default 0)</td></tr>
                        <tr><td>NOTAS</td><td>No</td><td>Observaciones</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
