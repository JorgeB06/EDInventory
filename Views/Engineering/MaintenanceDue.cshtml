@model IEnumerable<EDInventory.Models.Entities.EngMaintenance>
@{
    ViewData["Title"] = "Mantenimientos Pendientes — Servicio";
    var today = (DateOnly)ViewBag.Today;
    bool canWrite = User.IsInRole(AppRoles.Admin) || User.IsInRole(AppRoles.SvcAdmin) || User.IsInRole(AppRoles.SvcTecnico);
    var vencidos = Model.Where(m => m.MaintScheduled < today).ToList();
    var proximos = Model.Where(m => m.MaintScheduled >= today && m.MaintScheduled <= today.AddDays(30)).ToList();
    var futuros  = Model.Where(m => m.MaintScheduled > today.AddDays(30)).ToList();
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-wrench-adjustable me-2"></i>Mantenimientos Pendientes — Servicio</h4>
    <div class="d-flex gap-2 align-items-center">
        @if (vencidos.Any()) { <span class="badge bg-danger">@vencidos.Count vencido(s)</span> }
        @if (proximos.Any()) { <span class="badge bg-warning text-dark">@proximos.Count en 30 dias</span> }
        <span class="badge bg-secondary">@Model.Count() total</span>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
        No hay mantenimientos pendientes.
    </div>
}
else
{
    @* Vencidos *@
    @if (vencidos.Any())
    {
        <div class="card shadow-sm border-danger mb-3">
            <div class="card-header bg-danger text-white fw-bold">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>Vencidos (@vencidos.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Activo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th style="width:50px"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in vencidos)
                        {
                            var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                            <tr class="table-danger">
                                <td class="fw-semibold small"><a asp-action="AssetDetail" asp-route-id="@m.AssetCode" class="text-decoration-none text-dark">@m.Asset?.AssetDesc</a></td>
                                <td class="small text-muted">@(m.Asset?.Hospital?.HospName ?? "—")</td>
                                <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="badge bg-danger ms-1">@Math.Abs(dias)d</span></td>
                                <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                <td class="text-end">@if (canWrite) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Proximos 30 dias *@
    @if (proximos.Any())
    {
        <div class="card shadow-sm border-warning mb-3">
            <div class="card-header bg-warning text-dark fw-bold">
                <i class="bi bi-calendar-event me-1"></i>Proximos 30 Dias (@proximos.Count)
            </div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr><th>Activo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th>Notas</th><th style="width:50px"></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var m in proximos.OrderBy(x => x.MaintScheduled))
                        {
                            var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                            <tr class="@(dias <= 7 ? "table-warning" : "")">
                                <td class="fw-semibold small"><a asp-action="AssetDetail" asp-route-id="@m.AssetCode" class="text-decoration-none text-dark">@m.Asset?.AssetDesc</a></td>
                                <td class="small text-muted">@(m.Asset?.Hospital?.HospName ?? "—")</td>
                                <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="badge bg-warning text-dark ms-1">@dias d</span></td>
                                <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                <td class="small text-muted">@(m.MaintNotes ?? "—")</td>
                                <td class="text-end">@if (canWrite) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* Futuros (+30 dias) *@
    @if (futuros.Any())
    {
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white fw-bold"
                 style="cursor:pointer;" data-bs-toggle="collapse" data-bs-target="#colFuturos">
                <i class="bi bi-calendar3 me-1"></i>Mas de 30 Dias (@futuros.Count)
                <i class="bi bi-chevron-down small float-end"></i>
            </div>
            <div class="collapse" id="colFuturos">
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr><th>Activo</th><th>Hospital</th><th>Tipo</th><th>Fecha</th><th>Técnico</th><th>Notas</th><th style="width:50px"></th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in futuros.OrderBy(x => x.MaintScheduled))
                            {
                                var dias = m.MaintScheduled.DayNumber - today.DayNumber;
                                <tr>
                                    <td class="fw-semibold small"><a asp-action="AssetDetail" asp-route-id="@m.AssetCode" class="text-decoration-none text-dark">@m.Asset?.AssetDesc</a></td>
                                    <td class="small text-muted">@(m.Asset?.Hospital?.HospName ?? "—")</td>
                                    <td><span class="badge @(m.MaintType == "PREVENTIVO" ? "bg-primary" : m.MaintType == "CALIBRACION" ? "bg-info text-dark" : "bg-danger")">@m.MaintType</span></td>
                                    <td class="small">@m.MaintScheduled.ToString("dd/MM/yyyy") <span class="text-muted small ms-1">(@dias d)</span></td>
                                    <td class="small">@(m.User?.Employee != null ? $"{m.User.Employee.EmpName} {m.User.Employee.EmpSurname}" : m.User?.UserLogin ?? "—")</td>
                                    <td class="small text-muted">@(m.MaintNotes ?? "—")</td>
                                    <td class="text-end">@if (canWrite) { <a asp-action="MaintComplete" asp-route-id="@m.MaintCode" class="btn btn-outline-success btn-sm py-0 px-1"><i class="bi bi-check-lg"></i></a> }</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
}
