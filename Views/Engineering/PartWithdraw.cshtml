@model EDInventory.Models.ViewModels.PartWithdrawVM
@{ ViewData["Title"] = "Movimiento de Repuesto"; }

<div class="d-flex align-items-center mb-3 gap-2">
    <a asp-action="BoxDetail" asp-route-id="@Model.BoxCode" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h4 class="mb-0"><i class="bi bi-box-arrow-right me-2 text-warning"></i>Movimiento de Repuesto</h4>
</div>

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">

        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <h6 class="text-muted mb-2"><i class="bi bi-info-circle me-1"></i>Repuesto</h6>
                <div class="fw-semibold fs-5">@Model.PartName</div>
                @if (!string.IsNullOrWhiteSpace(Model.PartRef))
                {
                    <div class="text-muted small font-monospace">Cód: @Model.PartRef</div>
                }
                <div class="mt-2">
                    <span class="badge @(Model.CurrentQty == 0 ? "bg-danger" : Model.CurrentQty <= 2 ? "bg-warning text-dark" : "bg-success") fs-6">
                        Stock actual: @Model.CurrentQty
                    </span>
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="PartWithdraw" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="PartCode" />
                    <input type="hidden" asp-for="BoxCode" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Tipo de movimiento</label>
                        <div class="d-flex gap-3">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="MovType" value="RETIRO" id="chkRetiro" checked>
                                <label class="form-check-label text-danger fw-semibold" for="chkRetiro">
                                    <i class="bi bi-box-arrow-right me-1"></i>Retiro
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="MovType" value="DEVOLUCION" id="chkDevol">
                                <label class="form-check-label text-success fw-semibold" for="chkDevol">
                                    <i class="bi bi-box-arrow-in-left me-1"></i>Devolución
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="MovType" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Qty" class="form-label fw-semibold">Cantidad</label>
                        <input asp-for="Qty" class="form-control" type="number" min="1" style="max-width:140px;" />
                        <span asp-validation-for="Qty" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HospCode" class="form-label fw-semibold">Hospital destino <span class="text-muted fw-normal">(opcional)</span></label>
                        <select asp-for="HospCode" asp-items="Model.Hospitals" class="form-select">
                            <option value="">-- Sin especificar --</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label fw-semibold">Notas <span class="text-muted fw-normal">(opcional)</span></label>
                        <textarea asp-for="Notes" class="form-control" rows="2" maxlength="200"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning flex-grow-1">
                            <i class="bi bi-check-lg me-1"></i>Registrar movimiento
                        </button>
                        <a asp-action="BoxDetail" asp-route-id="@Model.BoxCode" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
