@model IEnumerable<EDInventory.Models.Entities.EngLine>
@{
    ViewData["Title"] = "Reporte de Stock - Servicio";
    var generatedAt = (DateTime)ViewBag.GeneratedAt;
    var totalLineas = Model.Count();
    var totalCajas  = Model.Sum(l => l.Boxes.Count);
    var totalItems  = Model.Sum(l => l.Boxes.Sum(b => b.Parts.Count));
    var totalUnid   = Model.Sum(l => l.Boxes.Sum(b => b.Parts.Sum(p => p.PartQty)));
    var sinStock    = Model.Sum(l => l.Boxes.Sum(b => b.Parts.Count(p => p.PartQty == 0)));
    var bajoStock   = Model.Sum(l => l.Boxes.Sum(b => b.Parts.Count(p => p.PartQty > 0 && p.PartQty <= 2)));
}

<style>
    @@media print {
        .d-print-none { display: none !important; }
        .d-none.d-print-block { display: block !important; }
        .table { font-size: 10px; }
        .card { break-inside: avoid; }
        body { font-size: 11px; }
        h5 { font-size: 13px; }
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3 d-print-none">
    <h4 class="mb-0"><i class="bi bi-file-earmark-text me-2"></i>Reporte de Stock — Servicio</h4>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-printer me-1"></i>Imprimir / PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver
        </a>
    </div>
</div>

<div class="d-none d-print-block mb-3">
    <h4 class="fw-bold">Reporte de Stock — División Servicio</h4>
    <p class="text-muted small mb-0">Generado el @generatedAt.ToString("dd/MM/yyyy HH:mm")</p>
</div>

<!-- Resumen -->
<div class="row g-3 mb-4">
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-primary">@totalLineas</div>
                <div class="small text-muted">Líneas</div>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-secondary">@totalCajas</div>
                <div class="small text-muted">Cajas</div>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-dark">@totalItems</div>
                <div class="small text-muted">Ítems</div>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-success">@totalUnid</div>
                <div class="small text-muted">Unidades</div>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-danger">@sinStock</div>
                <div class="small text-muted">Sin stock</div>
            </div>
        </div>
    </div>
    <div class="col-4 col-md-2">
        <div class="card text-center shadow-sm">
            <div class="card-body py-2">
                <div class="fs-4 fw-bold text-warning">@bajoStock</div>
                <div class="small text-muted">Bajo stock</div>
            </div>
        </div>
    </div>
</div>

@foreach (var line in Model)
{
    <div class="mb-4">
        <h5 class="text-primary border-bottom pb-1 mb-2">
            <i class="bi bi-diagram-2 me-1"></i>@line.LineName
            @if (!string.IsNullOrWhiteSpace(line.LineGroup))
            {
                <small class="text-muted fw-normal ms-2">(@line.LineGroup)</small>
            }
        </h5>

        @foreach (var box in line.Boxes)
        {
            if (!box.Parts.Any()) { continue; }
            <div class="card shadow-sm mb-2">
                <div class="card-header py-1 d-flex justify-content-between align-items-center bg-light">
                    <span class="fw-semibold small">
                        <i class="bi bi-box me-1"></i>Caja @box.BoxNumber
                        @if (!string.IsNullOrWhiteSpace(box.BoxDesc))
                        {
                            <span class="text-muted fw-normal">— @box.BoxDesc</span>
                        }
                    </span>
                    @if (box.Warehouse != null)
                    {
                        <span class="text-muted small">
                            <i class="bi bi-geo-alt me-1"></i>@box.Warehouse.WareName
                            @if (!string.IsNullOrWhiteSpace(box.WareRack)) { @(" / " + box.WareRack) }
                        </span>
                    }
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Cód.</th>
                                <th>Parte Fab.</th>
                                <th>Repuesto</th>
                                <th class="text-center" style="width:80px">Cantidad</th>
                                <th>Notas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var part in box.Parts)
                            {
                                <tr @(part.PartQty == 0 ? "class=table-danger" : part.PartQty <= 2 ? "class=table-warning" : "")>
                                    <td class="font-monospace small">@part.PartRef</td>
                                    <td class="font-monospace small">@part.PartMfrRef</td>
                                    <td>@part.PartName</td>
                                    <td class="text-center fw-bold @(part.PartQty == 0 ? "text-danger" : part.PartQty <= 2 ? "text-warning" : "")">
                                        @part.PartQty
                                    </td>
                                    <td class="text-muted small">@part.PartNotes</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
}
