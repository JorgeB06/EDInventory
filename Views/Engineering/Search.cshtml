@model IEnumerable<EDInventory.Models.Entities.EngPart>
@{
    ViewData["Title"] = "Buscar Repuesto";
    var query = ViewBag.Query as string;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-search me-2"></i>Buscar Repuesto</h4>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Volver
    </a>
</div>

<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group" style="max-width: 500px;">
        <input type="text" name="q" value="@query" class="form-control" placeholder="Código interno, parte fabricante o nombre..." autofocus />
        <button class="btn btn-primary" type="submit"><i class="bi bi-search me-1"></i>Buscar</button>
    </div>
</form>

@if (query != null)
{
    @if (!Model.Any())
    {
        <div class="alert alert-warning">No se encontraron repuestos para "<strong>@query</strong>".</div>
    }
    else
    {
        <p class="text-muted small mb-2">@Model.Count() resultado(s) para "<strong>@query</strong>"</p>
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead class="table-dark">
                    <tr>
                        <th>Línea</th>
                        <th>Caja</th>
                        <th>Cód. Interno</th>
                        <th>Parte Fab.</th>
                        <th>Repuesto</th>
                        <th class="text-center">Cant.</th>
                        <th>Notas</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var part in Model)
                    {
                        <tr>
                            <td>
                                <a asp-action="LineDetail" asp-route-id="@part.Box?.LineCode" class="text-decoration-none">
                                    @part.Box?.Line?.LineName
                                </a>
                            </td>
                            <td>Caja @part.Box?.BoxNumber</td>
                            <td class="font-monospace small">@part.PartRef</td>
                            <td class="font-monospace small text-primary">@part.PartMfrRef</td>
                            <td>@part.PartName</td>
                            <td class="text-center">
                                <span class="badge @(part.PartQty == 0 ? "bg-danger" : part.PartQty <= 2 ? "bg-warning text-dark" : "bg-success")">
                                    @part.PartQty
                                </span>
                            </td>
                            <td class="text-muted small">@part.PartNotes</td>
                            <td>
                                <a asp-action="PartEdit" asp-route-id="@part.PartCode" class="btn btn-outline-primary btn-sm py-0">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}
