@model EDInventory.Models.Entities.EngBox
@{
    ViewData["Title"] = "Editar Caja";
    var warehouses = ViewBag.Warehouses as IEnumerable<EDInventory.Models.Entities.Warehouse> ?? [];
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Editar Caja @Model.BoxNumber — @Model.Line?.LineName</h5>
            </div>
            <div class="card-body">
                <form asp-action="BoxEdit" method="post" class="tecnico-confirm">
                    @Html.AntiForgeryToken()
                    <input asp-for="BoxCode" type="hidden" />
                    <input asp-for="LineCode" type="hidden" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Número de caja <span class="text-danger">*</span></label>
                        <input asp-for="BoxNumber" class="form-control" type="number" min="1" />
                        <span asp-validation-for="BoxNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input asp-for="BoxDesc" class="form-control" />
                    </div>

                    <hr class="my-3" />
                    <p class="text-muted small mb-3"><i class="bi bi-geo-alt me-1"></i>Ubicación en bodega (opcional)</p>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Bodega</label>
                        <select asp-for="WareCode" class="form-select">
                            <option value="">— Sin bodega asignada —</option>
                            @foreach (var w in warehouses)
                            {
                                <option value="@w.WareCode" selected="@(Model.WareCode == w.WareCode)">@w.WareName</option>
                            }
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Rack</label>
                            <input asp-for="WareRack" class="form-control" placeholder="Ej: R1" />
                        </div>
                        <div class="col-6 mb-3">
                            <label class="form-label fw-semibold">Estante</label>
                            <input asp-for="WareEstante" class="form-control" placeholder="Ej: E3" />
                        </div>
                    </div>

                    <hr class="my-3" />

                    <div class="mb-4 form-check">
                        <input asp-for="Active" class="form-check-input" />
                        <label asp-for="Active" class="form-check-label">Activa</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Guardar cambios
                        </button>
                        <a asp-action="LineDetail" asp-route-id="@Model.LineCode" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
