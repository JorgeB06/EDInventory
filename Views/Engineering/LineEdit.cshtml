@model EDInventory.Models.Entities.EngLine
@{
    ViewData["Title"] = "Editar Línea";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Editar Línea — @Model.LineName</h5>
            </div>
            <div class="card-body">
                <form asp-action="LineEdit" method="post" class="tecnico-confirm">
                    @Html.AntiForgeryToken()
                    <input asp-for="LineCode" type="hidden" />
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre de la línea <span class="text-danger">*</span></label>
                        <input asp-for="LineName" class="form-control" />
                        <span asp-validation-for="LineName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Grupo (opcional)</label>
                        <input asp-for="LineGroup" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input asp-for="LineDesc" class="form-control" />
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="Active" class="form-check-input" />
                        <label asp-for="Active" class="form-check-label">Activa</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-circle me-1"></i>Guardar cambios
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
