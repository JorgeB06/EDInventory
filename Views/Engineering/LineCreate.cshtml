@model EDInventory.Models.Entities.EngLine
@{
    ViewData["Title"] = "Nueva Línea";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Nueva Línea de Ingeniería</h5>
            </div>
            <div class="card-body">
                <form asp-action="LineCreate" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Nombre de la línea <span class="text-danger">*</span></label>
                        <input asp-for="LineName" class="form-control" placeholder="Ej: OCD, FujiFilm, FASC LYRIC" />
                        <span asp-validation-for="LineName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Grupo (opcional)</label>
                        <input asp-for="LineGroup" class="form-control" placeholder="Ej: Citometría (agrupa varias líneas)" />
                        <div class="form-text">Use el mismo nombre de grupo para que las líneas aparezcan juntas.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Descripción</label>
                        <input asp-for="LineDesc" class="form-control" placeholder="Descripción breve (opcional)" />
                    </div>
                    <div class="mb-4 form-check">
                        <input asp-for="Active" class="form-check-input" />
                        <label asp-for="Active" class="form-check-label">Activa</label>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success">
                            <i class="bi bi-check-circle me-1"></i>Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
