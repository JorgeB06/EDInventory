@model EDInventory.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AssetCore — Iniciar sesión</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        html, body { height: 100%; margin: 0; font-family: 'Segoe UI', system-ui, sans-serif; }

        .login-wrap { display: flex; min-height: 100vh; }

        /* ── Panel izquierdo ── */
        .login-left {
            width: 68%;
            background: linear-gradient(150deg, #0d1117 0%, #1a1a2e 40%, #16213e 70%, #0f3460 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: space-between;
            padding: 3rem 4rem 2.5rem;
            position: relative;
            overflow: hidden;
        }

        /* Dot-grid */
        .login-left::before {
            content: '';
            position: absolute;
            inset: 0;
            background-image: radial-gradient(circle, rgba(255,255,255,.06) 1px, transparent 1px);
            background-size: 30px 30px;
            pointer-events: none;
        }

        /* Resplandor cian central */
        .login-left::after {
            content: '';
            position: absolute;
            top: 42%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 650px;
            height: 650px;
            background: radial-gradient(circle, rgba(13,202,240,.06) 0%, transparent 68%);
            pointer-events: none;
        }

        .left-content {
            position: relative;
            z-index: 1;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            justify-content: center;
            gap: 3.5rem;
        }

        /* Logo principal */
        .brand-block { text-align: center; }

        .brand-logo {
            max-height: 110px;
            max-width: 480px;
            width: 80%;
            object-fit: contain;
            filter: brightness(1.1);
        }

        .brand-tagline {
            color: rgba(255,255,255,.38);
            font-size: .78rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            margin-top: 1rem;
        }

        /* Separador */
        .brand-divider {
            width: 48px;
            height: 2px;
            background: linear-gradient(90deg, transparent, rgba(13,202,240,.6), transparent);
            margin: 0 auto .85rem;
        }

        /* Tres pilares */
        .pillars {
            display: flex;
            gap: 1.5rem;
            width: 100%;
            max-width: 540px;
        }

        .pillar {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: .85rem;
            padding: 1.6rem 1rem;
            background: rgba(255,255,255,.04);
            border: 1px solid rgba(255,255,255,.07);
            border-radius: 16px;
            transition: border-color .25s, background .25s;
        }

        .pillar:hover {
            background: rgba(13,202,240,.06);
            border-color: rgba(13,202,240,.25);
        }

        .pillar-ring {
            width: 54px;
            height: 54px;
            border-radius: 50%;
            border: 1.5px solid rgba(13,202,240,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
            color: rgba(13,202,240,.85);
            background: rgba(13,202,240,.07);
        }

        .pillar-label {
            font-size: .75rem;
            font-weight: 700;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: rgba(255,255,255,.5);
        }

        /* Pie izquierdo */
        .left-footer {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .left-footer img {
            max-height: 44px;
            object-fit: contain;
            opacity: .4;
            filter: grayscale(1) brightness(2.5);
        }

        .left-footer p {
            color: rgba(255,255,255,.2);
            font-size: .7rem;
            margin: .5rem 0 0;
        }

        /* ── Panel derecho ── */
        .login-right {
            width: 32%;
            min-width: 300px;
            background: #ffffff;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2.5rem 2rem;
            position: relative;
        }

        .login-form-wrap {
            width: 100%;
            max-width: 280px;
        }

        .login-eyebrow {
            font-size: .68rem;
            font-weight: 700;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: #0dcaf0;
            margin-bottom: .35rem;
        }

        .login-heading {
            font-size: 1.55rem;
            font-weight: 700;
            color: #1a1a2e;
            margin-bottom: .25rem;
            line-height: 1.2;
        }

        .login-sub {
            color: #9ca3af;
            font-size: .8rem;
            margin-bottom: 1.8rem;
        }

        .field-label {
            font-size: .75rem;
            font-weight: 600;
            color: #6b7280;
            margin-bottom: .28rem;
            display: block;
        }

        .input-icon-wrap {
            position: relative;
            margin-bottom: .9rem;
        }

        .input-icon-wrap .field-icon {
            position: absolute;
            left: .85rem;
            top: 50%;
            transform: translateY(-50%);
            color: #c4c9d4;
            font-size: .9rem;
            pointer-events: none;
            transition: color .2s;
        }

        .login-field {
            width: 100%;
            padding: .62rem .85rem .62rem 2.3rem;
            border: 1.5px solid #e5e7eb;
            border-radius: 9px;
            font-size: .88rem;
            background: #f9fafb;
            color: #1a1a2e;
            outline: none;
            transition: border-color .2s, background .2s, box-shadow .2s;
        }

        .login-field:focus {
            border-color: #0f3460;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(15,52,96,.1);
        }

        .input-icon-wrap:focus-within .field-icon { color: #0f3460; }

        .btn-login {
            width: 100%;
            padding: .7rem;
            background: linear-gradient(135deg, #1a1a2e 0%, #0f3460 100%);
            color: #fff;
            border: none;
            border-radius: 9px;
            font-size: .88rem;
            font-weight: 600;
            letter-spacing: .02em;
            cursor: pointer;
            transition: opacity .2s, transform .1s;
            margin-top: .4rem;
        }

        .btn-login:hover  { opacity: .87; }
        .btn-login:active { transform: scale(.985); }

        .login-version {
            position: absolute;
            bottom: 1.1rem;
            color: #d1d5db;
            font-size: .67rem;
            letter-spacing: .03em;
        }

        @@media (max-width: 991px) {
            .login-left  { display: none; }
            .login-right { width: 100%; min-height: 100vh; }
        }
    </style>
</head>
<body>
<div class="login-wrap">

    <!-- ═══════════════ PANEL IZQUIERDO ═══════════════ -->
    <div class="login-left">
        <div class="left-content">

            <!-- Logo + tagline -->
            <div class="brand-block">
                <img src="~/images/ASSETCORE-LOGO-SF.png" class="brand-logo" alt="AssetCore" />
                <div class="brand-divider"></div>
                <p class="brand-tagline">Plataforma interna &bull; Diagnostika S.A.</p>
            </div>

            <!-- Tres pilares abstractos -->
            <div class="pillars">
                <div class="pillar">
                    <div class="pillar-ring"><i class="bi bi-shield-check"></i></div>
                    <span class="pillar-label">Control</span>
                </div>
                <div class="pillar">
                    <div class="pillar-ring"><i class="bi bi-graph-up"></i></div>
                    <span class="pillar-label">Visibilidad</span>
                </div>
                <div class="pillar">
                    <div class="pillar-ring"><i class="bi bi-arrow-repeat"></i></div>
                    <span class="pillar-label">Trazabilidad</span>
                </div>
            </div>

        </div>

        <!-- Pie -->
        <div class="left-footer">
            <img src="~/images/logo-diagnostika.png" alt="Diagnostika S.A." />
            <p>Diagnostika S.A. &copy; @DateTime.Now.Year</p>
        </div>
    </div>

    <!-- ═══════════════ PANEL DERECHO ═══════════════ -->
    <div class="login-right">
        <div class="login-form-wrap">

            <p class="login-eyebrow">Acceso restringido</p>
            <h1 class="login-heading">Iniciar sesión</h1>
            <p class="login-sub">Ingrese sus credenciales para continuar.</p>

            <form asp-action="Login" asp-controller="Auth" method="post" novalidate>
                @Html.AntiForgeryToken()

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger small py-2 mb-3" role="alert">
                        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="bi bi-exclamation-circle me-1"></i>@e.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="mb-1">
                    <label class="field-label" for="UserLogin">Usuario</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-person field-icon"></i>
                        <input asp-for="UserLogin" id="UserLogin" class="login-field"
                               placeholder="Nombre de usuario" autocomplete="username" />
                    </div>
                    <span asp-validation-for="UserLogin" class="text-danger small"></span>
                </div>

                <div class="mb-1">
                    <label class="field-label" for="Password">Contraseña</label>
                    <div class="input-icon-wrap">
                        <i class="bi bi-lock field-icon"></i>
                        <input asp-for="Password" id="Password" class="login-field"
                               placeholder="Contraseña" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn-login">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                </button>
            </form>

        </div>

        <span class="login-version">AssetCore v1.0 &nbsp;&bull;&nbsp; Uso interno</span>
    </div>

</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
